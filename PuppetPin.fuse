-- Register the Fuse
FuRegisterClass("PuppetPin", CT_Tool, {
    REGS_Name = "Puppet Pin",
    REGS_Category = "Custom",
    REGS_OpIconString = "PP1",
})

local MAX_PINS = 4
PinEnabled = {}
PinPos = {}
PinStrength = {}
PinRadius = {}

InFalloffMode = nil
InInfluenceMode = nil
InMaxDisplace = nil
InQualityMode = nil
InDebugOverlay = nil
InDebugAlpha = nil
InUseMeshMask = nil
InMeshRebuild = nil
InRebuildMeshButton = nil
InMaskAlphaThreshold = nil
InMaskDownsample = nil
InMeshInteriorDensity = nil
InMeshInteriorJitter = nil
InMeshContourDensity = nil
InMeshExpand = nil
InMeshAlwaysDisplay = nil
InMeshThickness = nil
InMeshColorR = nil
InMeshColorG = nil
InMeshColorB = nil
InMeshAutoColor = nil
InRootLockEnable = nil
InRootLockPos = nil
InRootLockRadius = nil
InRootLockStrength = nil
InMeshMask = nil
InLocatorEnable = nil
InLocatorMode = nil

MeshCache = {
    key = nil,
    region = nil,
    verts = nil,
    tris = nil,
}

RebuildMeshScript = [[
MeshCache.key = nil
]]

MeshPreviewPulseTime = -1

-- Create Inputs/Outputs
function Create()
    -- Image input
    InImage = self:AddInput("Image", "Image", {
        LINKID_DataType = "Image",
        LINK_Main = 1
    })

    InMeshMask = self:AddInput("Secondary Mesh Mask", "MeshMask", {
        LINKID_DataType = "Image",
        INPID_InputControl = "ImageControl",
        INP_Required = false,
    })

    self:AddControlPage("Mesh")
    self:BeginControlNest("Mesh Build", "MeshNest", true, {})

    InRebuildMeshButton = self:AddInput("Rebuild Mesh", "RebuildMesh", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ButtonControl",
        INP_DoNotifyChanged = true,
    })

    InUseMeshMask = self:AddInput("Use Mesh Mask Input", "UseMeshMask", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_DoNotifyChanged = true,
    })

    InMeshRebuild = self:AddInput("Rebuild Every Frame", "MeshRebuild", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 1,
    })

    InMaskAlphaThreshold = self:AddInput("Mask Alpha Threshold", "MaskAlphaThreshold", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.03,
    })

    InMaskDownsample = self:AddInput("Mask Downsample", "MaskDownsample", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_Integer = true,
        INP_MinScale = 1,
        INP_MaxScale = 8,
        INP_Default = 1,
    })

    InMeshInteriorDensity = self:AddInput("Interior Point Spacing", "MeshInteriorDensity", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 4,
        INP_MaxScale = 128,
        INP_Default = 32,
    })

    InMeshInteriorJitter = self:AddInput("Interior Point Jitter", "MeshInteriorJitter", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.0,
    })

    InMeshContourDensity = self:AddInput("Contour Point Spacing", "MeshContourDensity", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 4,
        INP_MaxScale = 128,
        INP_Default = 32,
    })

    InMeshExpand = self:AddInput("Contour Point Expansion", "MeshExpand", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 0.5,
        INP_MinAllowed = 0.0,
        INP_MaxAllowed = 1.0,
        INP_Default = 0.02,
    })

    InMeshAlwaysDisplay = self:AddInput("Always Display Mesh", "MeshDebug", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })

    InMeshThickness = self:AddInput("Mesh Thickness", "MeshThickness", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_Integer = true,
        INP_MinScale = 1,
        INP_MaxScale = 5,
        INP_Default = 2,
    })

    InMeshColorR = self:AddInput("Red", "MeshColorR", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.95,
    })

    InMeshColorG = self:AddInput("Green", "MeshColorG", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.2,
    })

    InMeshColorB = self:AddInput("Blue", "MeshColorB", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 0.2,
    })

    InMeshAutoColor = self:AddInput("Auto Color Instance Nodes", "MeshAutoColor", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })

    self:EndControlNest()

    -- Create tab order: Mesh, Pins, Deformers, Solver, Locators, Settings
    self:AddControlPage("Pins")
    self:AddControlPage("Deformers")
    self:AddControlPage("Solver")
    self:AddControlPage("Locators")
    self:AddControlPage("Settings")
    self:AddControlPage("Solver")

    InFalloffMode = self:AddInput("Falloff Mode", "FalloffMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 1,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 2,
        { CCS_AddString = "Linear", },
        { CCS_AddString = "Smoothstep", },
        { CCS_AddString = "Gaussian", },
    })

    InInfluenceMode = self:AddInput("Influence Mode", "InfluenceMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 2,
        { CCS_AddString = "Sum", },
        { CCS_AddString = "Max", },
        { CCS_AddString = "Normalized Sum", },
    })

    InMaxDisplace = self:AddInput("Max Displacement", "MaxDisplacement", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.01,
        INP_MaxScale = 0.50,
        INP_MinAllowed = 0.001,
        INP_MaxAllowed = 2.0,
        INP_Default = 0.20,
    })

    self:AddControlPage("Settings")

    InQualityMode = self:AddInput("Quality", "QualityMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 1,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 1,
        { CCS_AddString = "Draft", },
        { CCS_AddString = "High", },
    })

    InDebugOverlay = self:AddInput("Show Influence Overlay", "DebugOverlay", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_DoNotifyChanged = true,
    })

    InDebugAlpha = self:AddInput("Overlay Opacity", "DebugAlpha", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.01,
        INP_MaxScale = 1.0,
        INP_MinAllowed = 0.0,
        INP_MaxAllowed = 1.0,
        INP_Default = 0.35,
        IC_Visible = false,
    })

    self:AddControlPage("Deformers")
    self:BeginControlNest("Root Lock", "RootLockNest", true, {})

    InRootLockEnable = self:AddInput("Enable Root Lock", "RootLockEnable", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_DoNotifyChanged = true,
    })

    InRootLockPos = self:AddInput("Root Position", "RootLockPos", {
        LINKID_DataType = "Point",
        INPID_InputControl = "OffsetControl",
        INPID_PreviewControl = "CrosshairControl",
        INP_DefaultX = 0.5,
        INP_DefaultY = 0.5,
        INP_DoNotifyChanged = true,
        IC_Visible = false,
    })
    InRootLockPos:SetAttrs({ PC_Visible = false })

    InRootLockRadius = self:AddInput("Root Radius", "RootLockRadius", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.01,
        INP_MaxScale = 1.0,
        INP_MinAllowed = 0.001,
        INP_MaxAllowed = 2.0,
        INP_Default = 0.15,
        IC_Visible = false,
    })

    InRootLockStrength = self:AddInput("Root Strength", "RootLockStrength", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_MinAllowed = 0.0,
        INP_MaxAllowed = 1.0,
        INP_Default = 1.0,
        IC_Visible = false,
    })

    self:EndControlNest()

    self:BeginControlNest("Follower Deformer", "FollowerNest", false, {})
    self:AddInput("Coming Soon: Follower", "FollowerPlaceholder", {
        LINKID_DataType = "Number",
        INPID_InputControl = "LabelControl",
    })
    self:EndControlNest()

    self:BeginControlNest("Wave Deformer", "WaveNest", false, {})
    self:AddInput("Coming Soon: Wave", "WavePlaceholder", {
        LINKID_DataType = "Number",
        INPID_InputControl = "LabelControl",
    })
    self:EndControlNest()

    self:BeginControlNest("IK/FK Deformer", "IKFKNest", false, {})
    self:AddInput("Coming Soon: IK/FK", "IKFKPlaceholder", {
        LINKID_DataType = "Number",
        INPID_InputControl = "LabelControl",
    })
    self:EndControlNest()

    self:AddControlPage("Pins")

    for i = 1, MAX_PINS do
        self:BeginControlNest("Pin " .. i, "PinNest" .. i, i == 1, {})

        PinEnabled[i] = self:AddInput("Enable", "Enable" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "CheckboxControl",
            INP_Integer = true,
            INP_Default = (i == 1) and 1 or 0,
            INP_DoNotifyChanged = true,
        })

        PinPos[i] = self:AddInput("Position", "Pin" .. i, {
            LINKID_DataType = "Point",
            INPID_InputControl = "OffsetControl",
            INPID_PreviewControl = "PointControl",
            INP_DefaultX = 0.5,
            INP_DefaultY = 0.5,
            INP_DoNotifyChanged = true,
            IC_Visible = (i == 1),
        })
        PinPos[i]:SetAttrs({ PC_Visible = (i == 1) })

        PinStrength[i] = self:AddInput("Strength", "Strength" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -0.2,
            INP_MaxScale = 0.2,
            INP_MinAllowed = -1.0,
            INP_MaxAllowed = 1.0,
            INP_Default = 0.08,
            IC_Visible = (i == 1),
        })

        PinRadius[i] = self:AddInput("Radius", "Radius" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = 0.01,
            INP_MaxScale = 1.0,
            INP_MinAllowed = 0.001,
            INP_MaxAllowed = 2.0,
            INP_Default = 0.20,
            IC_Visible = (i == 1),
        })

        self:EndControlNest()
    end

    self:AddControlPage("Locators")
    self:BeginControlNest("Locators", "LocatorsNest", true, {})
    InLocatorEnable = self:AddInput("Enable Locators", "LocatorEnable", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })
    InLocatorMode = self:AddInput("Locator Source", "LocatorMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 0,
        { CCS_AddString = "Pin", },
        { CCS_AddString = "Vertex", },
    })
    self:AddInput("Outputs coming in next phase", "LocatorPlaceholder", {
        LINKID_DataType = "Number",
        INPID_InputControl = "LabelControl",
    })
    self:EndControlNest()

    -- Main image output
    OutImage = self:AddOutput("Output", "Output", {
        LINKID_DataType = "Image",
        LINK_Main = 1
