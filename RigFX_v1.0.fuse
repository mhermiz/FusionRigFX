-- Register the Fuse
FuRegisterClass("RigFX_v1_0", CT_Tool, {
    REGS_Name = "1mar.io1 RigFX_v1.0",
    REGS_Category = "Custom",
    REGS_OpIconString = "RFX",
    REG_TimeVariant = true,
})

-- Hard cap used for UI generation and runtime loops.
local MAX_PINS = 32
local MAX_FOLLOWERS = 8
local MAX_WAVES = 8
PinEnabled = {}
PinPos = {}
PinStrength = {}
PinRadius = {}
PinRotation = {}
PinExpansion = {}

InFalloffMode = nil
InInfluenceMode = nil
InMaxDisplace = nil
InQualityMode = nil
InDebugOverlay = nil
InDebugAlpha = nil
InDebugRenderToOutput = nil
InLogFpsMetrics = nil
InMeshDiagnosticMode = nil
InMeshDiagnosticThreshold = nil
InMeshDebugOutputMode = nil
InMeshFillCracks = nil
InRebuildMeshButton = nil
InMaskAlphaThreshold = nil
InMaskDownsample = nil
InMeshInteriorDensity = nil
InMeshInteriorJitter = nil
InMeshContourDensity = nil
InMeshExpand = nil
InMeshAlwaysDisplay = nil
InMeshThickness = nil
InMeshColor = nil
InMeshColorG = nil
InMeshColorB = nil
InMeshAutoColor = nil
InRootLockEnable = nil
InRootLockPos = nil
InRootLockRadius = nil
InRootLockStrength = nil
InMeshMask = nil
InWeightMask = nil
InUseWeightMask = nil
InWeightMaskLock = nil
InRigMode = nil
InFollowerCount = nil
InAddFollower = nil
InRemoveFollower = nil
FollowerEnable = {}
FollowerSource = {}
FollowerTarget = {}
FollowerAmpX = {}
FollowerAmpY = {}
FollowerAmpRot = {}
FollowerAmpExp = {}
FollowerHeader = {}
FollowerCountState = 1
InWaveCount = nil
InAddWave = nil
InRemoveWave = nil
WaveEnable = {}
WaveBase = {}
WaveStart = {}
WaveEnd = {}
WaveAmp = {}
WaveFreq = {}
WaveSpeed = {}
WavePhase = {}
WaveStretch = {}
WaveHeader = {}
WaveCountState = 1
InLocatorEnable = nil
InLocatorMode = nil

-- Cached mesh payload to avoid rebuilding expensive geometry every frame.
MeshCache = {
    key = nil,
    region = nil,
    verts = nil,
    tris = nil,
    mask = nil,
}

RebuildMeshScript = [[
MeshCache.key = nil
]]

-- Temporary countdown used to force mesh preview visibility after edits.
MeshPreviewCountdown = 0
PinBindPose = {}
DeformCache = { verts = {} }
-- Reusable runtime tables to reduce allocations during playback/drags.
RuntimeCache = {
    pins = {},
    activePins = {},
    prevPinX = {},
    prevPinY = {},
    interactHold = 0,
    wasInteracting = false,
    frame = 0,
    fpsMetrics = {
        enabled = false,
        prevTime = nil,
        frameCount = 0,
        lastFrameTime = nil,
    },
}

-- Create all inspector controls and IO ports for the Fuse.
function Create()
    local bannerBase64 = [[]]

    local function AddRigFXBanner(id)
        self:AddInput([[<center><img src="data:image/png;base64,]] .. bannerBase64 .. [[" width="300"></center>]], id, {
            LINKID_DataType = "Number",
            INPID_InputControl = "LabelControl",
            LBLC_DropDownButton = false,
            LBLC_MultiLine = true,
            IC_NoLabel = true,
            IC_ControlPage = -1,
            INP_External = false,
        })
    end
    local function AddRigFXControlPage(name)
        local icons = {
            Mesh = "Icons.Tools.Tabs.Matte",
            Pins = "Icons.Tools.Tabs.XYPath",
            Deformers = "Icons.Tools.Tabs.PolyLine",
            Solver = "Icons.Tools.Tabs.Operation",
            Locators = "Icons.Tools.Tabs.Tracker",
            Overlay = "Icons.Tools.Tabs.Display",
        }

        self:AddControlPage(name, {
            CTID_DIB_ID = icons[name],
        })
    end

    AddRigFXBanner("RigFXBannerHeader")
    self:RemoveControlPage("Controls")

    AddRigFXControlPage("Mesh")

    -- Primary image stream to be deformed.
    InImage = self:AddInput("Image", "Image", {
        LINKID_DataType = "Image",
        LINK_Main = 1
    })

    -- Optional mask used only for mesh extraction/building.
    InMeshMask = self:AddInput("Secondary Mesh Mask", "MeshMask", {
        LINKID_DataType = "Image",
        INPID_InputControl = "ImageControl",
        INP_Required = false,
    })

    -- Optional mask used during deformation to lock/weight movement.
    InWeightMask = self:AddInput("Secondary Weight Mask", "WeightMask", {
        LINKID_DataType = "Image",
        INPID_InputControl = "ImageControl",
        INP_Required = false,
    })

    -- Mesh page: controls that define mesh generation and debug display.
    self:BeginControlNest("Mesh Build", "MeshNest", true, {})

    InRebuildMeshButton = self:AddInput("Rebuild Mesh", "RebuildMesh", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ButtonControl",
        INP_DoNotifyChanged = true,
    })

    InMeshInteriorDensity = self:AddInput("Interior Point Spacing", "MeshInteriorDensity", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 4,
        INP_MaxScale = 128,
        INP_Default = 32,
        INP_DoNotifyChanged = true,
    })

    InMeshContourDensity = self:AddInput("Contour Point Spacing", "MeshContourDensity", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 4,
        INP_MaxScale = 128,
        INP_Default = 32,
        INP_DoNotifyChanged = true,
    })

    InMeshExpand = self:AddInput("Contour Point Expansion", "MeshExpand", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 0.5,
        INP_MinAllowed = 0.0,
        INP_MaxAllowed = 1.0,
        INP_Default = 0.02,
        INP_DoNotifyChanged = true,
    })

    InMeshAlwaysDisplay = self:AddInput("Always Display Mesh", "MeshDebug", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })

    InMeshThickness = self:AddInput("Mesh Thickness", "MeshThickness", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_Integer = true,
        INP_MinScale = 1,
        INP_MaxScale = 5,
        INP_Default = 2,
    })

    InMeshColor = self:AddInput("Mesh Color", "MeshColor", {
        ICS_Name = "Mesh Color",
        LINKID_DataType = "Number",
        INPID_InputControl = "ColorControl",
        INP_Default = 0.95,
        INP_DoNotifyChanged = true,
        IC_ControlGroup = 77,
        IC_ControlID = 0,
    })

    InMeshColorG = self:AddInput("Green", "MeshColorG", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ColorControl",
        INP_Default = 0.2,
        INP_DoNotifyChanged = true,
        IC_ControlGroup = 77,
        IC_ControlID = 1,
    })

    InMeshColorB = self:AddInput("Blue", "MeshColorB", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ColorControl",
        INP_Default = 0.2,
        INP_DoNotifyChanged = true,
        IC_ControlGroup = 77,
        IC_ControlID = 2,
    })

    InMeshAutoColor = self:AddInput("Auto Color Instance Nodes", "MeshAutoColor", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })

    self:EndControlNest()

    -- Pre-register pages to stabilize tab ordering in the inspector.
    -- Final content for each page is added below.
    -- Intended order: Mesh, Pins, Deformers, Solver, Locators, Overlay.
    AddRigFXControlPage("Pins")
    AddRigFXControlPage("Deformers")
    AddRigFXControlPage("Solver")
    AddRigFXControlPage("Locators")
    AddRigFXControlPage("Overlay")

    -- Solver page: global deformation behavior shared across all pins.
    AddRigFXControlPage("Solver")

    InFalloffMode = self:AddInput("Falloff Mode", "FalloffMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 1,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 2,
        { CCS_AddString = "Linear", },
        { CCS_AddString = "Smoothstep", },
        { CCS_AddString = "Gaussian", },
    })

    InInfluenceMode = self:AddInput("Influence Mode", "InfluenceMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 2,
        { CCS_AddString = "Sum", },
        { CCS_AddString = "Max", },
        { CCS_AddString = "Normalized Sum", },
    })

    InMaxDisplace = self:AddInput("Max Displacement", "MaxDisplacement", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.01,
        INP_MaxScale = 0.50,
        INP_MinAllowed = 0.001,
        INP_MaxAllowed = 2.0,
        INP_Default = 0.20,
    })

    -- Overlay page: debug visualization controls.
    AddRigFXControlPage("Overlay")

    InQualityMode = self:AddInput("Quality", "QualityMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 1,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 1,
        { CCS_AddString = "Draft", },
        { CCS_AddString = "High", },
    })

    InDebugOverlay = self:AddInput("Show Influence Overlay", "DebugOverlay", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_DoNotifyChanged = true,
    })

    InDebugAlpha = self:AddInput("Overlay Opacity", "DebugAlpha", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.01,
        INP_MaxScale = 1.0,
        INP_MinAllowed = 0.0,
        INP_MaxAllowed = 1.0,
        INP_Default = 0.35,
        IC_Visible = false,
    })

    InDebugRenderToOutput = self:AddInput("Render Overlay/Mesh to Output", "DebugRenderToOutput", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 1,
    })

    InLogFpsMetrics = self:AddInput("Log FPS Metrics", "LogFpsMetrics", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_DoNotifyChanged = true,
    })

    InMeshDiagnosticMode = self:AddInput("Mesh Diagnostics", "MeshDiagnosticMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 3,
        { CCS_AddString = "Off", },
        { CCS_AddString = "Contour Sources", },
        { CCS_AddString = "Long Triangles", },
        { CCS_AddString = "Warp Bounds", },
    })

    InMeshDiagnosticThreshold = self:AddInput("Diagnostic Threshold", "MeshDiagnosticThreshold", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 4.0,
        INP_MaxScale = 256.0,
        INP_MinAllowed = 1.0,
        INP_MaxAllowed = 2048.0,
        INP_Default = 80.0,
    })

    InMeshDebugOutputMode = self:AddInput("Debug Output Mode", "MeshDebugOutputMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 3,
        { CCS_AddString = "Normal", },
        { CCS_AddString = "Warp Only", },
        { CCS_AddString = "Full Mask Clear", },
        { CCS_AddString = "No Hole Fill", },
    })

    InMeshFillCracks = self:AddInput("Fill Transparent Cracks", "MeshFillCracks", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })

    -- Deformers page: root lock + placeholders for upcoming deformer systems.
    AddRigFXControlPage("Deformers")
    self:BeginControlNest("Root Lock", "RootLockNest", true, {})

    InRootLockEnable = self:AddInput("Enable Root Lock", "RootLockEnable", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_DoNotifyChanged = true,
    })

    InRootLockPos = self:AddInput("Root Position", "RootLockPos", {
        LINKID_DataType = "Point",
        INPID_InputControl = "OffsetControl",
        INPID_PreviewControl = "CrosshairControl",
        INP_DefaultX = 0.5,
        INP_DefaultY = 0.5,
        INP_DoNotifyChanged = true,
        IC_Visible = false,
    })
    InRootLockPos:SetAttrs({ PC_Visible = false })

    InRootLockRadius = self:AddInput("Root Radius", "RootLockRadius", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.01,
        INP_MaxScale = 1.0,
        INP_MinAllowed = 0.001,
        INP_MaxAllowed = 2.0,
        INP_Default = 0.15,
        IC_Visible = false,
    })

    InRootLockStrength = self:AddInput("Root Strength", "RootLockStrength", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_MinAllowed = 0.0,
        INP_MaxAllowed = 1.0,
        INP_Default = 1.0,
        IC_Visible = false,
    })

    self:EndControlNest()

    self:BeginControlNest("Follower Deformer", "FollowerNest", false, {})
    InAddFollower = self:AddInput("Add Follower", "AddFollower", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ButtonControl",
        INP_DoNotifyChanged = true,
    })
    InRemoveFollower = self:AddInput("Remove Follower", "RemoveFollower", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ButtonControl",
        INP_DoNotifyChanged = true,
    })
    for i = 1, MAX_FOLLOWERS do
        FollowerHeader[i] = self:AddInput("Follower " .. i, "FollowerHeader" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "LabelControl",
            IC_Visible = (i == 1),
        })
        FollowerEnable[i] = self:AddInput("Enable", "FollowerEnable" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "CheckboxControl",
            INP_Integer = true,
            INP_Default = 0,
            IC_Visible = (i == 1),
        })
        FollowerSource[i] = self:AddInput("Source Pin", "FollowerSource" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_Integer = true,
            INP_MinScale = 1,
            INP_MaxScale = MAX_PINS,
            INP_MinAllowed = 1,
            INP_MaxAllowed = MAX_PINS,
            INP_Default = 1,
            IC_Visible = (i == 1),
        })
        FollowerTarget[i] = self:AddInput("Target Pin", "FollowerTarget" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_Integer = true,
            INP_MinScale = 1,
            INP_MaxScale = MAX_PINS,
            INP_MinAllowed = 1,
            INP_MaxAllowed = MAX_PINS,
            INP_Default = 2,
            IC_Visible = (i == 1),
        })
        FollowerAmpX[i] = self:AddInput("Follow X", "FollowerAmpX" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -2.0,
            INP_MaxScale = 2.0,
            INP_Default = 1.0,
            IC_Visible = (i == 1),
        })
        FollowerAmpY[i] = self:AddInput("Follow Y", "FollowerAmpY" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -2.0,
            INP_MaxScale = 2.0,
            INP_Default = 1.0,
            IC_Visible = (i == 1),
        })
        FollowerAmpRot[i] = self:AddInput("Follow Rotation", "FollowerAmpRot" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -2.0,
            INP_MaxScale = 2.0,
            INP_Default = 0.0,
            IC_Visible = (i == 1),
        })
        FollowerAmpExp[i] = self:AddInput("Follow Expansion", "FollowerAmpExp" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -2.0,
            INP_MaxScale = 2.0,
            INP_Default = 0.0,
            IC_Visible = (i == 1),
        })
    end
    self:AddInput("Delay/stacking in next pass", "FollowerPlaceholder", {
        LINKID_DataType = "Number",
        INPID_InputControl = "LabelControl",
    })
    self:EndControlNest()

    self:BeginControlNest("Wave Deformer", "WaveNest", false, {})
    InAddWave = self:AddInput("Add Wave", "AddWave", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ButtonControl",
        INP_DoNotifyChanged = true,
    })
    InRemoveWave = self:AddInput("Remove Wave", "RemoveWave", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ButtonControl",
        INP_DoNotifyChanged = true,
    })
    for i = 1, MAX_WAVES do
        WaveHeader[i] = self:AddInput("Wave " .. i, "WaveHeader" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "LabelControl",
            IC_Visible = (i == 1),
        })
        WaveEnable[i] = self:AddInput("Enable", "WaveEnable" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "CheckboxControl",
            INP_Integer = true,
            INP_Default = 0,
            IC_Visible = (i == 1),
        })
        WaveBase[i] = self:AddInput("Base Pin", "WaveBase" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_Integer = true,
            INP_MinScale = 1,
            INP_MaxScale = MAX_PINS,
            INP_MinAllowed = 1,
            INP_MaxAllowed = MAX_PINS,
            INP_Default = 1,
            IC_Visible = (i == 1),
        })
        WaveStart[i] = self:AddInput("Start Pin", "WaveStart" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_Integer = true,
            INP_MinScale = 1,
            INP_MaxScale = MAX_PINS,
            INP_MinAllowed = 1,
            INP_MaxAllowed = MAX_PINS,
            INP_Default = 2,
            IC_Visible = (i == 1),
        })
        WaveEnd[i] = self:AddInput("End Pin", "WaveEnd" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_Integer = true,
            INP_MinScale = 1,
            INP_MaxScale = MAX_PINS,
            INP_MinAllowed = 1,
            INP_MaxAllowed = MAX_PINS,
            INP_Default = 6,
            IC_Visible = (i == 1),
        })
        WaveAmp[i] = self:AddInput("Amplitude", "WaveAmp" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = 0.0,
            INP_MaxScale = 0.25,
            INP_MinAllowed = 0.0,
            INP_MaxAllowed = 1.0,
            INP_Default = 0.03,
            IC_Visible = (i == 1),
        })
        WaveFreq[i] = self:AddInput("Frequency", "WaveFreq" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = 0.1,
            INP_MaxScale = 6.0,
            INP_MinAllowed = 0.01,
            INP_MaxAllowed = 20.0,
            INP_Default = 1.5,
            IC_Visible = (i == 1),
        })
        WaveSpeed[i] = self:AddInput("Speed", "WaveSpeed" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -4.0,
            INP_MaxScale = 4.0,
            INP_Default = 1.0,
            IC_Visible = (i == 1),
        })
        WavePhase[i] = self:AddInput("Phase", "WavePhase" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -6.283,
            INP_MaxScale = 6.283,
            INP_Default = 0.0,
            IC_Visible = (i == 1),
        })
        WaveStretch[i] = self:AddInput("Stretch", "WaveStretch" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -0.5,
            INP_MaxScale = 0.5,
            INP_Default = 0.0,
            IC_Visible = (i == 1),
        })
    end
    self:AddInput("Use ordered pin IDs as chain", "WaveHint", {
        LINKID_DataType = "Number",
        INPID_InputControl = "LabelControl",
    })
    self:EndControlNest()

    -- Pins page: global rig mode and weight-mask controls.
    AddRigFXControlPage("Pins")
    self:BeginControlNest("Pin Global", "PinGlobalNest", true, {})
    InRigMode = self:AddInput("Rig Mode", "RigMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 0,
        INP_MinAllowed = 0,
        INP_MaxAllowed = 1,
        INP_DoNotifyChanged = true,
        { CCS_AddString = "Setup", },
        { CCS_AddString = "Animate", },
    })
    InUseWeightMask = self:AddInput("Use Weight Mask", "UseWeightMask", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })
    InWeightMaskLock = self:AddInput("Weight Mask Lock", "WeightMaskLock", {
        LINKID_DataType = "Number",
        INPID_InputControl = "SliderControl",
        INP_MinScale = 0.0,
        INP_MaxScale = 1.0,
        INP_Default = 1.0,
    })
    self:EndControlNest()

    -- Generate repeated UI blocks for each pin slot.
    for i = 1, MAX_PINS do
        self:BeginControlNest("Pin " .. i, "PinNest" .. i, i == 1, {})

        -- Enable toggle controls visibility and runtime participation.
        PinEnabled[i] = self:AddInput("Enable", "Enable" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "CheckboxControl",
            INP_Integer = true,
            INP_Default = (i == 1) and 1 or 0,
            INP_DoNotifyChanged = true,
        })

        -- Viewer handle for this pin (shown by default only for pin 1).
        PinPos[i] = self:AddInput("Position", "Pin" .. i, {
            LINKID_DataType = "Point",
            INPID_InputControl = "OffsetControl",
            INPID_PreviewControl = "PointControl",
            INP_DefaultX = 0.5,
            INP_DefaultY = 0.5,
            INP_DoNotifyChanged = true,
            IC_Visible = (i == 1),
        })
        PinPos[i]:SetAttrs({ PC_Visible = (i == 1) })

        -- Translation influence strength.
        PinStrength[i] = self:AddInput("Pull", "Strength" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -2.0,
            INP_MaxScale = 2.0,
            INP_MinAllowed = -4.0,
            INP_MaxAllowed = 4.0,
            INP_Default = 1.0,
            IC_Visible = (i == 1),
        })

        -- Influence radius in normalized image space.
        PinRadius[i] = self:AddInput("Radius", "Radius" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = 0.01,
            INP_MaxScale = 1.0,
            INP_MinAllowed = 0.001,
            INP_MaxAllowed = 2.0,
            INP_Default = 0.20,
            IC_Visible = (i == 1),
        })

        -- Local rotational deformation around pin center.
        PinRotation[i] = self:AddInput("Rotation", "Rotation" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -180.0,
            INP_MaxScale = 180.0,
            INP_MinAllowed = -720.0,
            INP_MaxAllowed = 720.0,
            INP_Default = 0.0,
            IC_Visible = (i == 1),
        })

        -- Radial expansion/contraction deformation.
        PinExpansion[i] = self:AddInput("Expansion", "Expansion" .. i, {
            LINKID_DataType = "Number",
            INPID_InputControl = "SliderControl",
            INP_MinScale = -1.0,
            INP_MaxScale = 1.0,
            INP_MinAllowed = -2.0,
            INP_MaxAllowed = 2.0,
            INP_Default = 0.0,
            IC_Visible = (i == 1),
        })

        self:EndControlNest()
    end

    -- Locators page: placeholders for output tracking channels (next version).
    AddRigFXControlPage("Locators")
    self:BeginControlNest("Locators", "LocatorsNest", true, {})
    InLocatorEnable = self:AddInput("Enable Locators", "LocatorEnable", {
        LINKID_DataType = "Number",
        INPID_InputControl = "CheckboxControl",
        INP_Integer = true,
        INP_Default = 0,
    })
    InLocatorMode = self:AddInput("Locator Source", "LocatorMode", {
        LINKID_DataType = "Number",
        INPID_InputControl = "ComboControl",
        INP_Integer = true,
        INP_Default = 0,
        { CCS_AddString = "Pin", },
        { CCS_AddString = "Vertex", },
    })
    self:AddInput("Outputs coming in next version", "LocatorPlaceholder", {
        LINKID_DataType = "Number",
        INPID_InputControl = "LabelControl",
    })
    self:EndControlNest()

    -- Main image output
    OutImage = self:AddOutput("Output", "Output", {
        LINKID_DataType = "Image",
        LINK_Main = 1
    })
end

-- Show/hide per-pin controls when a pin is enabled/disabled.
local function setPinUiVisible(i, enabled)
    local show = enabled and true or false
    PinPos[i]:SetAttrs({ IC_Visible = show, PC_Visible = show })
    PinStrength[i]:SetAttrs({ IC_Visible = show })
    PinRadius[i]:SetAttrs({ IC_Visible = show })
    PinRotation[i]:SetAttrs({ IC_Visible = show })
    PinExpansion[i]:SetAttrs({ IC_Visible = show })
end

-- Only show overlay opacity when overlay itself is enabled.
local function setDebugUiVisible(enabled)
    InDebugAlpha:SetAttrs({ IC_Visible = enabled and true or false })
end

-- Toggle root lock sub-controls visibility.
local function setRootLockUiVisible(enabled)
    local show = enabled and true or false
    InRootLockPos:SetAttrs({ IC_Visible = show, PC_Visible = show })
    InRootLockRadius:SetAttrs({ IC_Visible = show })
    InRootLockStrength:SetAttrs({ IC_Visible = show })
end

local function setFollowerSlotUiVisible(i, enabled)
    local show = enabled and true or false
    FollowerHeader[i]:SetAttrs({ IC_Visible = show })
    FollowerEnable[i]:SetAttrs({ IC_Visible = show })
    FollowerSource[i]:SetAttrs({ IC_Visible = show })
    FollowerTarget[i]:SetAttrs({ IC_Visible = show })
    FollowerAmpX[i]:SetAttrs({ IC_Visible = show })
    FollowerAmpY[i]:SetAttrs({ IC_Visible = show })
    FollowerAmpRot[i]:SetAttrs({ IC_Visible = show })
    FollowerAmpExp[i]:SetAttrs({ IC_Visible = show })
end

local function setWaveSlotUiVisible(i, enabled)
    local show = enabled and true or false
    WaveHeader[i]:SetAttrs({ IC_Visible = show })
    WaveEnable[i]:SetAttrs({ IC_Visible = show })
    WaveBase[i]:SetAttrs({ IC_Visible = show })
    WaveStart[i]:SetAttrs({ IC_Visible = show })
    WaveEnd[i]:SetAttrs({ IC_Visible = show })
    WaveAmp[i]:SetAttrs({ IC_Visible = show })
    WaveFreq[i]:SetAttrs({ IC_Visible = show })
    WaveSpeed[i]:SetAttrs({ IC_Visible = show })
    WavePhase[i]:SetAttrs({ IC_Visible = show })
    WaveStretch[i]:SetAttrs({ IC_Visible = show })
end

local function applyFollowerCountVisibility(count)
    local n = math.floor(count or 0)
    if n < 0 then n = 0 end
    if n > MAX_FOLLOWERS then n = MAX_FOLLOWERS end
    for i = 1, MAX_FOLLOWERS do
        setFollowerSlotUiVisible(i, i <= n)
    end
end

local function applyWaveCountVisibility(count)
    local n = math.floor(count or 0)
    if n < 0 then n = 0 end
    if n > MAX_WAVES then n = MAX_WAVES end
    for i = 1, MAX_WAVES do
        setWaveSlotUiVisible(i, i <= n)
    end
end

local function readCountInput(inp, time, fallback)
    local ok, v = pcall(function() return inp:GetValue(time) end)
    if ok and v ~= nil then
        if type(v) == "number" then return v end
        local okVal, vv = pcall(function() return v.Value end)
        if okVal and type(vv) == "number" then return vv end
        local n = tonumber(v)
        if n ~= nil then return n end
    end
    return fallback
end

local function writeCountInput(inp, time, value)
    local v = math.floor(value + 0.5)
    local wrote = false
    local okSet = pcall(function() inp:Set(time, v) end)
    if okSet then wrote = true end
    local okSetValue = pcall(function() inp:SetValue(v, time) end)
    if okSetValue then wrote = true end
    local okIndex = pcall(function() inp[time] = v end)
    if okIndex then wrote = true end
    pcall(function() inp:SetAttrs({ INP_Default = v }) end)
    return wrote
end

-- Handle inspector interactions that need immediate side effects.
function NotifyChanged(inp, param, time)
    local t = tonumber(time) or 0

    if inp == InAddFollower or inp == InRemoveFollower then
        -- Button controls can fire on press/release; only act on press.
        if param == nil or (tonumber(param.Value) or 0) < 0.5 then
            return
        end
        if inp == InAddFollower then
            FollowerCountState = math.min(MAX_FOLLOWERS, math.floor((FollowerCountState or 1) + 1))
        else
            FollowerCountState = math.max(0, math.floor((FollowerCountState or 1) - 1))
        end
        applyFollowerCountVisibility(FollowerCountState)
        return
    end

    if inp == InAddWave or inp == InRemoveWave then
        -- Button controls can fire on press/release; only act on press.
        if param == nil or (tonumber(param.Value) or 0) < 0.5 then
            return
        end
        if inp == InAddWave then
            WaveCountState = math.min(MAX_WAVES, math.floor((WaveCountState or 1) + 1))
        else
            WaveCountState = math.max(0, math.floor((WaveCountState or 1) - 1))
        end
        applyWaveCountVisibility(WaveCountState)
        return
    end

    if param == nil then return end

    if inp == InRebuildMeshButton then
        MeshCache.key = nil
        MeshPreviewCountdown = 120
        return
    end

    if inp == InMeshInteriorDensity or inp == InMeshContourDensity or inp == InMeshExpand then
        MeshCache.key = nil
        MeshPreviewCountdown = 120
        return
    end

    if inp == InMeshColor then
        MeshPreviewCountdown = 120
        return
    end

    if inp == InMeshColorG or inp == InMeshColorB then
        MeshPreviewCountdown = 120
        return
    end

    for i = 1, MAX_PINS do
        if inp == PinEnabled[i] then
            local on = param.Value >= 0.5
            setPinUiVisible(i, on)
            if not on then
                PinBindPose[i] = nil
            end
            return
        end
    end

    if inp == InDebugOverlay then
        setDebugUiVisible(param.Value >= 0.5)
        return
    end

    if inp == InLogFpsMetrics then
        RuntimeCache.fpsMetrics.enabled = false
        RuntimeCache.fpsMetrics.prevTime = nil
        RuntimeCache.fpsMetrics.frameCount = 0
        RuntimeCache.fpsMetrics.lastFrameTime = nil
        return
    end

    if inp == InRootLockEnable then
        setRootLockUiVisible(param.Value >= 0.5)
        return
    end

end

-- Deterministic color palette so each pin gets a stable debug color.
local function pinDebugColor(i)
    -- Deterministic hue wheel so each pin gets a distinct color across many pins.
    local h = ((i - 1) * 0.61803398875) % 1.0
    local s = 0.78
    local v = 1.0
    local c = v * s
    local hp = h * 6.0
    local x = c * (1.0 - math.abs((hp % 2.0) - 1.0))
    local r, g, b = 0.0, 0.0, 0.0

    if hp < 1.0 then
        r, g, b = c, x, 0.0
    elseif hp < 2.0 then
        r, g, b = x, c, 0.0
    elseif hp < 3.0 then
        r, g, b = 0.0, c, x
    elseif hp < 4.0 then
        r, g, b = 0.0, x, c
    elseif hp < 5.0 then
        r, g, b = x, 0.0, c
    else
        r, g, b = c, 0.0, x
    end

    local m = v - c
    return r + m, g + m, b + m
end

-- Utility clamp used throughout numeric input and geometry code.
local function clamp(v, lo, hi)
    if v < lo then return lo end
    if v > hi then return hi end
    return v
end

-- Extract a usable mask scalar from various image channel formats.
local function maskValueAtPixel(p)
    -- Handle regular RGBA images and single-channel mask images.
    local a = p.A
    if a == nil then a = p.W end
    if a == nil then a = p.Y end
    if a ~= nil then return tonumber(a) or 0.0 end

    local r = tonumber(p.R) or tonumber(p.X) or 0.0
    local g = tonumber(p.G) or r
    local b = tonumber(p.B) or r
    return math.max(r, g, b)
end

-- Compute tight subject bounds from mask alpha, with optional expansion.
local function buildMaskRegion(maskImg, w, h, expandN, alphaThreshold, downsample)
    local p = Pixel(maskImg)
    local stride = math.max(1, math.floor(downsample or 1))
    local minX, minY = w - 1, h - 1
    local maxX, maxY = 0, 0
    local found = false

    for y = 0, h - 1, stride do
        for x = 0, w - 1, stride do
            maskImg:GetPixel(x, y, p)
            if maskValueAtPixel(p) > (alphaThreshold or 0.01) then
                found = true
                if x < minX then minX = x end
                if y < minY then minY = y end
                if x > maxX then maxX = x end
                if y > maxY then maxY = y end
            end
        end
    end

    -- Ensure right/bottom edges are considered even when stride > 1.
    if not found and stride > 1 then
        for y = 0, h - 1 do
            maskImg:GetPixel(w - 1, y, p)
            if maskValueAtPixel(p) > (alphaThreshold or 0.01) then
                found = true
                minX = math.min(minX, w - 1); maxX = math.max(maxX, w - 1)
                minY = math.min(minY, y);     maxY = math.max(maxY, y)
            end
        end
        for x = 0, w - 1 do
            maskImg:GetPixel(x, h - 1, p)
            if maskValueAtPixel(p) > (alphaThreshold or 0.01) then
                found = true
                minX = math.min(minX, x);     maxX = math.max(maxX, x)
                minY = math.min(minY, h - 1); maxY = math.max(maxY, h - 1)
            end
        end
    end

    if not found then
        return { x0 = 0, y0 = 0, x1 = w - 1, y1 = h - 1 }
    end

    local expandPx = math.floor(clamp(expandN, 0.0, 1.0) * math.min(w, h) + 0.5)
    return {
        x0 = clamp(minX - expandPx, 0, w - 1),
        y0 = clamp(minY - expandPx, 0, h - 1),
        x1 = clamp(maxX + expandPx, 0, w - 1),
        y1 = clamp(maxY + expandPx, 0, h - 1),
    }
end

-- Pre-sample mask occupancy in mesh bounds to avoid repeated GetPixel calls.
local function buildMaskCache(maskImg, region, alphaThreshold)
    local w = maskImg.Width
    local h = maskImg.Height
    local x0 = clamp(math.floor(region.x0), 0, w - 1)
    local y0 = clamp(math.floor(region.y0), 0, h - 1)
    local x1 = clamp(math.floor(region.x1), 0, w - 1)
    local y1 = clamp(math.floor(region.y1), 0, h - 1)
    local rw = math.max(1, x1 - x0 + 1)
    local rh = math.max(1, y1 - y0 + 1)
    local thr = alphaThreshold or 0.01
    local p = Pixel(maskImg)
    local data = {}
    local idx = 1
    for y = y0, y1 do
        for x = x0, x1 do
            maskImg:GetPixel(x, y, p)
            data[idx] = (maskValueAtPixel(p) > thr) and 1 or 0
            idx = idx + 1
        end
    end
    return { x0 = x0, y0 = y0, x1 = x1, y1 = y1, w = rw, h = rh, data = data }
end

-- Extract, resample, smooth, and expand contour points around masked subject.
local function extractContourPoints(maskImg, region, alphaThreshold, contourSpacing, borderExpandPx)
    local mp = Pixel(maskImg)
    local thr = alphaThreshold or 0.01
    local w = maskImg.Width
    local h = maskImg.Height
    local x0 = clamp(math.floor(region.x0), 0, w - 1)
    local x1 = clamp(math.floor(region.x1), 0, w - 1)
    local y0 = clamp(math.floor(region.y0), 0, h - 1)
    local y1 = clamp(math.floor(region.y1), 0, h - 1)

    local spacing = math.max(2.0, contourSpacing)
    local approxPerim = math.max(1.0, 2.0 * ((x1 - x0) + (y1 - y0)))
    local contourSampleSpacing = math.max(2.0, spacing * 0.5)
    local maxContourPoints = clamp(math.floor(approxPerim / contourSampleSpacing + 0.5), 24, 420)

    local contourExpandPx = math.max(0.0, borderExpandPx or 0.0)
    local dilateRadius = math.min(32, math.max(0, math.ceil(contourExpandPx)))
    local bx0 = clamp(x0 - dilateRadius - 1, 0, w - 1)
    local by0 = clamp(y0 - dilateRadius - 1, 0, h - 1)
    local bx1 = clamp(x1 + dilateRadius + 1, 0, w - 1)
    local by1 = clamp(y1 + dilateRadius + 1, 0, h - 1)
    local cachePad = dilateRadius + 5
    local cx0 = clamp(bx0 - cachePad, 0, w - 1)
    local cy0 = clamp(by0 - cachePad, 0, h - 1)
    local cx1 = clamp(bx1 + cachePad, 0, w - 1)
    local cy1 = clamp(by1 + cachePad, 0, h - 1)
    local cw = math.max(1, cx1 - cx0 + 1)
    local ch = math.max(1, cy1 - cy0 + 1)

    local baseMask = {}
    local idx = 1
    for yy = cy0, cy1 do
        for xx = cx0, cx1 do
            maskImg:GetPixel(xx, yy, mp)
            baseMask[idx] = (maskValueAtPixel(mp) > thr) and 1 or 0
            idx = idx + 1
        end
    end

    local function cacheIndex(px, py)
        return ((py - cy0) * cw) + (px - cx0) + 1
    end
    local function insidePixel(px, py)
        if px < cx0 or px > cx1 or py < cy0 or py > cy1 then return false end
        return baseMask[cacheIndex(px, py)] == 1
    end

    local contourMask = baseMask
    if dilateRadius > 0 then
        local hMask = {}
        for yy = cy0, cy1 do
            local rowBase = (yy - cy0) * cw
            local prefix = { 0 }
            local running = 0
            for xx = cx0, cx1 do
                running = running + (baseMask[rowBase + (xx - cx0) + 1] or 0)
                prefix[(xx - cx0) + 2] = running
            end
            for xx = cx0, cx1 do
                local lo = math.max(cx0, xx - dilateRadius)
                local hi = math.min(cx1, xx + dilateRadius)
                local count = prefix[(hi - cx0) + 2] - prefix[(lo - cx0) + 1]
                hMask[rowBase + (xx - cx0) + 1] = (count > 0) and 1 or 0
            end
        end

        contourMask = {}
        for xx = cx0, cx1 do
            local prefix = { 0 }
            local running = 0
            for yy = cy0, cy1 do
                running = running + (hMask[((yy - cy0) * cw) + (xx - cx0) + 1] or 0)
                prefix[(yy - cy0) + 2] = running
            end
            for yy = cy0, cy1 do
                local lo = math.max(cy0, yy - dilateRadius)
                local hi = math.min(cy1, yy + dilateRadius)
                local count = prefix[(hi - cy0) + 2] - prefix[(lo - cy0) + 1]
                contourMask[((yy - cy0) * cw) + (xx - cx0) + 1] = (count > 0) and 1 or 0
            end
        end
    end

    local function contourInsidePixel(px, py)
        if px < cx0 or px > cx1 or py < cy0 or py > cy1 then return false end
        return contourMask[cacheIndex(px, py)] == 1
    end

    local points = {}
    local adjacency = {}
    local function pointKey(px, py)
        return tostring(px) .. ":" .. tostring(py)
    end
    local function ensurePoint(px, py)
        local key = pointKey(px, py)
        if not points[key] then
            points[key] = { x = px, y = py }
            adjacency[key] = {}
        end
        return key
    end
    local function addEdge(ax, ay, bx, by)
        local a = ensurePoint(ax, ay)
        local b = ensurePoint(bx, by)
        adjacency[a][b] = true
        adjacency[b][a] = true
    end

    -- Build true boundary edges from the expanded alpha footprint.
    for y = by0, by1 do
        for x = bx0, bx1 do
            if contourInsidePixel(x, y) then
                if not contourInsidePixel(x, y - 1) then addEdge(x, y, x + 1, y) end
                if not contourInsidePixel(x + 1, y) then addEdge(x + 1, y, x + 1, y + 1) end
                if not contourInsidePixel(x, y + 1) then addEdge(x + 1, y + 1, x, y + 1) end
                if not contourInsidePixel(x - 1, y) then addEdge(x, y + 1, x, y) end
            end
        end
    end

    local function edgeKey(a, b)
        if a < b then return a .. "|" .. b end
        return b .. "|" .. a
    end

    local visitedEdges = {}
    local bestLoop = nil
    local bestLen = 0.0
    for startKey, neighbors in pairs(adjacency) do
        for nextKey in pairs(neighbors) do
            local firstEdge = edgeKey(startKey, nextKey)
            if not visitedEdges[firstEdge] then
                local loop = { { x = points[startKey].x, y = points[startKey].y } }
                local loopLen = 0.0
                local prevKey = nil
                local curKey = startKey
                local curNextKey = nextKey
                local guard = 0

                while curNextKey and guard < 20000 do
                    guard = guard + 1
                    visitedEdges[edgeKey(curKey, curNextKey)] = true

                    local cur = points[curKey]
                    local nxt = points[curNextKey]
                    local dx = nxt.x - cur.x
                    local dy = nxt.y - cur.y
                    loopLen = loopLen + math.sqrt((dx * dx) + (dy * dy))
                    loop[#loop + 1] = { x = nxt.x, y = nxt.y }

                    if curNextKey == startKey then break end

                    local candidate = nil
                    for k in pairs(adjacency[curNextKey]) do
                        if k ~= curKey and not visitedEdges[edgeKey(curNextKey, k)] then
                            candidate = k
                            break
                        end
                    end
                    if not candidate then
                        for k in pairs(adjacency[curNextKey]) do
                            if k ~= prevKey and not visitedEdges[edgeKey(curNextKey, k)] then
                                candidate = k
                                break
                            end
                        end
                    end

                    prevKey = curKey
                    curKey = curNextKey
                    curNextKey = candidate
                end

                if #loop >= 8 and loopLen > bestLen then
                    bestLoop = loop
                    bestLen = loopLen
                end
            end
        end
    end

    if not bestLoop then return nil end
    if #bestLoop >= 2 then
        local first = bestLoop[1]
        local last = bestLoop[#bestLoop]
        if math.abs(first.x - last.x) < 1e-6 and math.abs(first.y - last.y) < 1e-6 then
            bestLoop[#bestLoop] = nil
        end
    end

    local out = bestLoop
    if #out < 8 then return nil end

    local function polyLength(poly)
        local len = 0.0
        for i = 1, #poly do
            local j = (i % #poly) + 1
            local dx = poly[j].x - poly[i].x
            local dy = poly[j].y - poly[i].y
            len = len + math.sqrt((dx * dx) + (dy * dy))
        end
        return len
    end

    local function resampleClosed(poly, count)
        local n = #poly
        if n < 3 or count < 3 then return poly end

        local segLen = {}
        local total = 0.0
        for i = 1, n do
            local j = (i % n) + 1
            local dx = poly[j].x - poly[i].x
            local dy = poly[j].y - poly[i].y
            local d = math.sqrt((dx * dx) + (dy * dy))
            segLen[i] = d
            total = total + d
        end
        if total <= 1e-6 then return poly end

        local step = total / count
        local outPts = {}
        local segIdx = 1
        local segPos = 0.0

        -- Uniformly place `count` samples by walking arc-length along polygon edges.
        for si = 0, count - 1 do
            local targetDist = si * step

            -- Advance to the segment that contains this target distance.
            while segIdx <= n and (segPos + segLen[segIdx]) < targetDist do
                segPos = segPos + segLen[segIdx]
                segIdx = segIdx + 1
                if segIdx > n then segIdx = 1 end
            end

            local a = poly[segIdx]
            local b = poly[(segIdx % n) + 1]
            local d = segLen[segIdx]
            local t = 0.0
            if d > 1e-6 then
                t = (targetDist - segPos) / d
            end
            t = clamp(t, 0.0, 1.0)

            outPts[#outPts + 1] = {
                x = a.x + ((b.x - a.x) * t),
                y = a.y + ((b.y - a.y) * t),
            }
        end

        return outPts
    end

    local initialLen = polyLength(out)
    local desiredCount = clamp(math.floor(initialLen / contourSampleSpacing + 0.5), 16, maxContourPoints)
    out = resampleClosed(out, desiredCount)

    if #out > 8 then
        local smoothPasses = 0
        for _ = 1, smoothPasses do
            local sm = {}
            for i = 1, #out do
                local p0 = out[((i - 2 + #out) % #out) + 1]
                local p1 = out[i]
                local p2 = out[(i % #out) + 1]
                sm[i] = {
                    x = (p0.x * 0.15) + (p1.x * 0.70) + (p2.x * 0.15),
                    y = (p0.y * 0.15) + (p1.y * 0.70) + (p2.y * 0.15),
                }
            end
            out = sm
        end
        out = resampleClosed(out, desiredCount)
    end

    local function nearestInsideSource(px, py)
        local bx = math.floor(px)
        local by = math.floor(py)
        local bestX, bestY = nil, nil
        local bestD2 = 1e18
        for r = 0, 4 do
            for oy = -r, r do
                for ox = -r, r do
                    if math.abs(ox) == r or math.abs(oy) == r then
                        local ix = bx + ox
                        local iy = by + oy
                        if insidePixel(ix, iy) then
                            local sx = ix + 0.5
                            local sy = iy + 0.5
                            local dx = sx - px
                            local dy = sy - py
                            local d2 = (dx * dx) + (dy * dy)
                            if d2 < bestD2 then
                                bestD2 = d2
                                bestX = sx
                                bestY = sy
                            end
                        end
                    end
                end
            end
            if bestX then break end
        end
        return bestX or clamp(px, 0, w - 1), bestY or clamp(py, 0, h - 1)
    end

    for i = 1, #out do
        out[i].sx, out[i].sy = nearestInsideSource(out[i].x, out[i].y)
    end

    return out
end

-- Build deform mesh (contour + interior points + constrained triangulation).
local function buildGridMesh(region, interiorSpacing, contourSpacing, borderExpandPx, maskImg, alphaThreshold, interiorJitter)
    local thr = alphaThreshold or 0.01
    local mp = Pixel(maskImg)
    -- Fast point-in-mask probe used for point filtering/triangle validation.
    local function isInsideMask(px, py)
        local sx = clamp(math.floor(px + 0.5), 0, maskImg.Width - 1)
        local sy = clamp(math.floor(py + 0.5), 0, maskImg.Height - 1)
        maskImg:GetPixel(sx, sy, mp)
        return maskValueAtPixel(mp) > thr
    end

    local contour = extractContourPoints(maskImg, region, thr, contourSpacing, borderExpandPx) or {}
    local contourCount = #contour

    local interior = {}
    local seen = {}
    -- Deduplicate interior samples on integer pixel grid.
    local function addInterior(x, y, sx, sy, support)
        local k = tostring(math.floor(x + 0.5)) .. ":" .. tostring(math.floor(y + 0.5))
        if not seen[k] then
            local p = { x = x, y = y, sx = sx, sy = sy, support = support }
            seen[k] = p
            interior[#interior + 1] = p
            return p
        end
        if support then seen[k].support = true end
        return seen[k]
    end

    -- Ensure thin protrusions and detailed edges have nearby interior anchors even
    -- when the regular interior grid spacing skips over them.
    if contourCount > 0 then
        local supportStride = math.max(1, math.floor((contourCount / 240) + 0.5))
        for i = 1, contourCount, supportStride do
            local c = contour[i]
            local sx = c.sx or c.x
            local sy = c.sy or c.y
            if isInsideMask(sx, sy) then
                addInterior(sx, sy, sx, sy, true)
            end
        end
    end

    local step = math.max(2.0, interiorSpacing)
    local x0, y0, x1, y1 = region.x0, region.y0, region.x1, region.y1
    local regionArea = math.max(1.0, (x1 - x0 + 1) * (y1 - y0 + 1))
    local estInterior = math.floor(regionArea / math.max(4.0, step * step) + 0.5)
    local interiorLimit = math.floor(clamp(estInterior * 1.5, 120, 1400))

    for y = y0, y1, step do
        for x = x0, x1, step do
            local px, py = x, y
            if interiorJitter > 0.0 then
                local jx = (((x * 12.9898 + y * 78.233) % 1.0) - 0.5) * interiorJitter * step
                local jy = (((y * 39.3467 + x * 11.135) % 1.0) - 0.5) * interiorJitter * step
                px = clamp(px + jx, x0, x1)
                py = clamp(py + jy, y0, y1)
            end
            local ix = clamp(math.floor(px + 0.5), 0, maskImg.Width - 1)
            local iy = clamp(math.floor(py + 0.5), 0, maskImg.Height - 1)
            maskImg:GetPixel(ix, iy, mp)
            if maskValueAtPixel(mp) > thr then
                addInterior(px, py)
                if #interior >= interiorLimit then break end
            end
        end
        if #interior >= interiorLimit then break end
    end

    if contourCount > 0 and #interior == 0 then
        local cx, cy = 0.0, 0.0
        for i = 1, contourCount do
            cx = cx + contour[i].x
            cy = cy + contour[i].y
        end
        addInterior(cx / contourCount, cy / contourCount)
    end

    -- Add support rings when contour expansion is wider than the interior grid.
    -- Without these, expanded contour verts can connect to distant interior verts,
    -- creating long boundary triangles that stretch edge pixels during deformation.
    if contourCount >= 3 and borderExpandPx and borderExpandPx > step then
        local ringCount = math.ceil(borderExpandPx / step)
        ringCount = math.max(1, ringCount)
        local ringStride = math.max(1, math.floor((contourCount / 240) + 0.5))
        for r = 1, ringCount do
            local t = r / (ringCount + 1)
            for i = 1, contourCount, ringStride do
                local c = contour[i]
                local sx = c.sx or c.x
                local sy = c.sy or c.y
                local x = sx + ((c.x - sx) * t)
                local y = sy + ((c.y - sy) * t)
                addInterior(x, y, sx, sy, true)
            end
        end
    end

    -- Bowyer-Watson Delaunay triangulation over sampled points.
    local function delaunay(pts)
        if #pts < 3 then return {} end
        local all = {}
        local minX, minY = 1e12, 1e12
        local maxX, maxY = -1e12, -1e12
        for i = 1, #pts do
            all[i + 3] = pts[i]
            if pts[i].x < minX then minX = pts[i].x end
            if pts[i].y < minY then minY = pts[i].y end
            if pts[i].x > maxX then maxX = pts[i].x end
            if pts[i].y > maxY then maxY = pts[i].y end
        end
        local dx = maxX - minX
        local dy = maxY - minY
        local dmax = math.max(dx, dy)
        local midx = (minX + maxX) * 0.5
        local midy = (minY + maxY) * 0.5
        all[1] = { x = midx - (20 * dmax), y = midy - dmax }
        all[2] = { x = midx, y = midy + (20 * dmax) }
        all[3] = { x = midx + (20 * dmax), y = midy - dmax }

        local function circumContains(a, b, c, p)
            local ax = a.x - p.x
            local ay = a.y - p.y
            local bx = b.x - p.x
            local by = b.y - p.y
            local cx = c.x - p.x
            local cy = c.y - p.y
            local det = ((ax * ax + ay * ay) * (bx * cy - by * cx))
                      - ((bx * bx + by * by) * (ax * cy - ay * cx))
                      + ((cx * cx + cy * cy) * (ax * by - ay * bx))
            local orient = ((b.x - a.x) * (c.y - a.y)) - ((b.y - a.y) * (c.x - a.x))
            if orient >= 0 then return det > 1e-9 end
            return det < -1e-9
        end

        local triangles = { { 1, 2, 3 } }
        -- Insert points one-by-one: remove triangles whose circumcircle contains
        -- the point, then retriangulate the exposed polygonal cavity.
        for pi = 4, #all do
            local bad = {}
            local edges = {}
            for ti = 1, #triangles do
                local t = triangles[ti]
                if circumContains(all[t[1]], all[t[2]], all[t[3]], all[pi]) then
                    bad[ti] = true
                    local e = { { t[1], t[2] }, { t[2], t[3] }, { t[3], t[1] } }
                    -- Boundary extraction via edge parity:
                    -- shared edges cancel, unique edges form cavity border.
                    for ei = 1, 3 do
                        local a = math.min(e[ei][1], e[ei][2])
                        local b = math.max(e[ei][1], e[ei][2])
                        local k = tostring(a) .. ":" .. tostring(b)
                        if edges[k] then edges[k] = false else edges[k] = { a, b } end
                    end
                end
            end
            local kept = {}
            for ti = 1, #triangles do
                if not bad[ti] then kept[#kept + 1] = triangles[ti] end
            end
            triangles = kept
            for _, e in pairs(edges) do
                if e then triangles[#triangles + 1] = { e[1], e[2], pi } end
            end
        end

        local out = {}
        for i = 1, #triangles do
            local t = triangles[i]
            if t[1] > 3 and t[2] > 3 and t[3] > 3 then
                out[#out + 1] = { t[1] - 3, t[2] - 3, t[3] - 3 }
            end
        end
        return out
    end

    -- If contour points are too far from interior, add bridge interior points near edges.
    if contourCount >= 1 and #interior >= 1 then
        local bridgeLimit = math.max(interiorSpacing * 1.25, 8.0)
        -- Ensure contour vertices are not too far from nearest interior support.
        for ci = 1, contourCount do
            local c = contour[ci]
            local bestK, bestD2 = nil, 1e18
            for k = 1, #interior do
                local iv = interior[k]
                local dx = iv.x - c.x
                local dy = iv.y - c.y
                local d2 = (dx * dx) + (dy * dy)
                if d2 < bestD2 then
                    bestD2 = d2
                    bestK = k
                end
            end

            if bestK ~= nil then
                local d = math.sqrt(bestD2)
                if d > bridgeLimit then
                    local segs = math.floor(d / bridgeLimit + 0.5)
                    if segs < 2 then segs = 2 end
                    if segs > 6 then segs = 6 end

                    local iv = interior[bestK]
                    for s = 1, segs - 1 do
                        local t = s / segs
                        local bx = c.x + ((iv.x - c.x) * t)
                        local by = c.y + ((iv.y - c.y) * t)
                        local ix = clamp(math.floor(bx + 0.5), 0, maskImg.Width - 1)
                        local iy = clamp(math.floor(by + 0.5), 0, maskImg.Height - 1)
                        maskImg:GetPixel(ix, iy, mp)
                        if maskValueAtPixel(mp) > thr then
                            addInterior(bx, by)
                        end
                    end
                end
            end
        end

        -- Also bridge contour edge midpoints, not just contour vertices.
        if contourCount >= 2 then
            -- Also bridge edge midpoints to avoid long unsupported contour strips.
            for ci = 1, contourCount do
                local cj = (ci % contourCount) + 1
                local mx = (contour[ci].x + contour[cj].x) * 0.5
                local my = (contour[ci].y + contour[cj].y) * 0.5

                local bestK, bestD2 = nil, 1e18
                for k = 1, #interior do
                    local iv = interior[k]
                    local dx = iv.x - mx
                    local dy = iv.y - my
                    local d2 = (dx * dx) + (dy * dy)
                    if d2 < bestD2 then
                        bestD2 = d2
                        bestK = k
                    end
                end

                if bestK ~= nil then
                    local d = math.sqrt(bestD2)
                    if d > bridgeLimit then
                        local segs = math.floor(d / bridgeLimit + 0.5)
                        if segs < 2 then segs = 2 end
                        if segs > 6 then segs = 6 end

                        local iv = interior[bestK]
                        for s = 1, segs - 1 do
                            local t = s / segs
                            local bx = mx + ((iv.x - mx) * t)
                            local by = my + ((iv.y - my) * t)
                            local ix = clamp(math.floor(bx + 0.5), 0, maskImg.Width - 1)
                            local iy = clamp(math.floor(by + 0.5), 0, maskImg.Height - 1)
                            maskImg:GetPixel(ix, iy, mp)
                            if maskValueAtPixel(mp) > thr then
                                addInterior(bx, by)
                            end
                        end
                    end
                end
            end
        end
    end

    -- Guaranteed inner support layer: add interior points just inside contour.
    if contourCount >= 8 then
        -- Add an inner ring near contour so boundary deformation stays stable.
        local ccx, ccy = 0.0, 0.0
        for i = 1, contourCount do
            ccx = ccx + contour[i].x
            ccy = ccy + contour[i].y
        end
        ccx = ccx / contourCount
        ccy = ccy / contourCount

        local ringStep = math.max(2.0, contourSpacing * 0.75)
        local ringDepth = math.max(2.0, math.min(interiorSpacing * 0.9, contourSpacing * 0.8))
        for i = 1, contourCount do
            local j = (i % contourCount) + 1
            local ex = contour[j].x - contour[i].x
            local ey = contour[j].y - contour[i].y
            local el = math.sqrt((ex * ex) + (ey * ey))
            if el > 1e-6 then
                local segments = math.max(1, math.floor(el / ringStep + 0.5))
                for s = 0, segments - 1 do
                    local t = (s + 0.5) / segments
                    local px = contour[i].x + (ex * t)
                    local py = contour[i].y + (ey * t)

                    local nx = ccx - px
                    local ny = ccy - py
                    local nl = math.sqrt((nx * nx) + (ny * ny))
                    if nl > 1e-6 then
                        nx = nx / nl
                        ny = ny / nl
                        local bx = px + (nx * ringDepth)
                        local by = py + (ny * ringDepth)
                        local ix = clamp(math.floor(bx + 0.5), 0, maskImg.Width - 1)
                        local iy = clamp(math.floor(by + 0.5), 0, maskImg.Height - 1)
                        maskImg:GetPixel(ix, iy, mp)
                        if maskValueAtPixel(mp) > thr then
                            addInterior(bx, by)
                        end
                    end
                end
            end
        end
    end

    local verts = {}
    for i = 1, contourCount do verts[#verts + 1] = contour[i] end
    for i = 1, #interior do verts[#verts + 1] = interior[i] end

    local tris = {}
    local interiorOffset = contourCount

    -- Stabilized triangulation over all vertices with geometric and mask guards.
    local allTris = delaunay(verts)
    for i = 1, #allTris do
        local t = allTris[i]
        local a = verts[t[1]]
        local b = verts[t[2]]
        local c = verts[t[3]]
        local aContour = (t[1] <= contourCount)
        local bContour = (t[2] <= contourCount)
        local cContour = (t[3] <= contourCount)
        local contourVerts = (aContour and 1 or 0) + (bContour and 1 or 0) + (cContour and 1 or 0)
        local supportVerts = ((a.support and 1) or 0) + ((b.support and 1) or 0) + ((c.support and 1) or 0)

        local abx, aby = b.x - a.x, b.y - a.y
        local bcx, bcy = c.x - b.x, c.y - b.y
        local cax, cay = a.x - c.x, a.y - c.y
        local ab2 = (abx * abx) + (aby * aby)
        local bc2 = (bcx * bcx) + (bcy * bcy)
        local ca2 = (cax * cax) + (cay * cay)
        local maxL2 = math.max(ab2, math.max(bc2, ca2))

        -- Skip contour-only faces; keep edge strip linear and connect it to interior.
        if contourVerts < 3 then
            local maxEdge
            if contourVerts == 0 then
                maxEdge = math.max(interiorSpacing * 2.8, 18.0)
            elseif contourVerts == 1 then
                maxEdge = math.max(interiorSpacing * 5.0, contourSpacing * 4.5, borderExpandPx * 2.0 + 14.0, 24.0)
            else
                maxEdge = math.max(interiorSpacing * 4.0, contourSpacing * 3.2, borderExpandPx * 1.6 + 12.0, 20.0)
            end
            local maxEdge2 = maxEdge * maxEdge
            if maxL2 <= maxEdge2 then
            local cx = (a.x + b.x + c.x) / 3
            local cy = (a.y + b.y + c.y) / 3
            local abx = (a.x + b.x) * 0.5
            local aby = (a.y + b.y) * 0.5
            local bcx = (b.x + c.x) * 0.5
            local bcy = (b.y + c.y) * 0.5
            local cax = (c.x + a.x) * 0.5
            local cay = (c.y + a.y) * 0.5

            -- Multi-sample inside test (vertices + centroid + edge midpoints)
            -- rejects most exterior/invalid faces while keeping boundary slivers.
            local insideVotes = 0
            if isInsideMask(a.x, a.y) then insideVotes = insideVotes + 1 end
            if isInsideMask(b.x, b.y) then insideVotes = insideVotes + 1 end
            if isInsideMask(c.x, c.y) then insideVotes = insideVotes + 1 end
            if isInsideMask(cx, cy) then insideVotes = insideVotes + 1 end
            if isInsideMask(abx, aby) then insideVotes = insideVotes + 1 end
            if isInsideMask(bcx, bcy) then insideVotes = insideVotes + 1 end
            if isInsideMask(cax, cay) then insideVotes = insideVotes + 1 end

            -- Boundary triangles can be thin; allow if any probe is inside.
            -- Expanded support-ring points live outside the alpha mask, so allow
            -- local band triangles that contain support/contour vertices too.
            if insideVotes >= 1 or (supportVerts > 0 and (supportVerts + contourVerts) >= 2) then
                tris[#tris + 1] = { t[1], t[2], t[3] }
            end
            end
        end
    end

    -- Explicitly stitch contour edges to nearest interior to ensure connectivity.
    if contourCount >= 2 and #interior >= 1 then
        local maxAttach = math.max(interiorSpacing * 3.2, contourSpacing * 2.0, borderExpandPx + 12.0, 18.0)
        local maxAttach2 = maxAttach * maxAttach
        local used = {}
        -- Explicitly add contour-edge-to-interior triangles to guarantee linkage.
        for i = 1, contourCount do
            local j = (i % contourCount) + 1
            local mx = (verts[i].x + verts[j].x) * 0.5
            local my = (verts[i].y + verts[j].y) * 0.5
            local bestK, bestD2 = nil, 1e18
            for k = 1, #interior do
                local iv = verts[interiorOffset + k]
                local dx = iv.x - mx
                local dy = iv.y - my
                local d2 = (dx * dx) + (dy * dy)
                if d2 < bestD2 then
                    bestD2 = d2
                    bestK = k
                end
            end

            if bestK and bestD2 <= maxAttach2 then
                local a1 = math.min(i, j)
                local b1 = math.max(i, j)
                local c1 = interiorOffset + bestK
                local key = tostring(a1) .. ":" .. tostring(b1) .. ":" .. tostring(c1)
                if not used[key] then
                    used[key] = true
                    tris[#tris + 1] = { i, j, c1 }
                end
            end
        end
    end

    return verts, tris, contourCount
end

-- Draw a square point marker with configurable thickness in output image.
local function drawMeshPoint(out, px, py, w, h, thickness, pix)
    for oy = -thickness + 1, thickness - 1 do
        for ox = -thickness + 1, thickness - 1 do
            local x = px + ox
            local y = py + oy
            if x >= 0 and x < w and y >= 0 and y < h then
                out:SetPixel(x, y, pix)
            end
        end
    end
end

-- Draw line as repeated point stamps (simple raster utility for debug mesh).
local function drawMeshLine(out, x0, y0, x1, y1, w, h, thickness, pix)
    local dx = x1 - x0
    local dy = y1 - y0
    local steps = math.max(math.abs(dx), math.abs(dy))
    if steps < 1 then
        drawMeshPoint(out, math.floor(x0 + 0.5), math.floor(y0 + 0.5), w, h, thickness, pix)
        return
    end

    local sx = dx / steps
    local sy = dy / steps
    local x = x0
    local y = y0
    for _ = 0, steps do
        drawMeshPoint(out, math.floor(x + 0.5), math.floor(y + 0.5), w, h, thickness, pix)
        x = x + sx
        y = y + sy
    end
end

-- Draw pin handle marker (white backing + colored crosshair).
local function drawPinMarker(out, px, py, w, h, r, g, b)
    local outer = Pixel(out)
    outer.R = 1.0
    outer.G = 1.0
    outer.B = 1.0
    outer.A = 1.0

    local cross = Pixel(out)
    cross.R = math.max(0.0, math.min(1.0, r or 1.0))
    cross.G = math.max(0.0, math.min(1.0, g or 0.2))
    cross.B = math.max(0.0, math.min(1.0, b or 0.2))
    cross.A = 1.0

    local x = math.floor(px + 0.5)
    local y = math.floor(py + 0.5)

    -- Opaque white backing prevents red mesh/overlay bleed near the handle.
    drawMeshPoint(out, x, y, w, h, 10, outer)

    -- Small crosshair to keep pins visible over dense red mesh lines.
    drawMeshLine(out, x - 16, y, x + 16, y, w, h, 2, cross)
    drawMeshLine(out, x, y - 16, x, y + 16, w, h, 2, cross)
    drawMeshPoint(out, x, y, w, h, 2, cross)
end

-- Safe numeric getter for Fuse inputs (handles table/value wrappers).
local function inputNumber(inp, req, def)
    local ok, v = pcall(function() return inp:GetValue(req) end)
    if (not ok) or v == nil then return def end

    if type(v) == "number" then return v end

    local okVal, vv = pcall(function() return v.Value end)
    if okVal and type(vv) == "number" then return vv end

    local n = tonumber(v)
    if n ~= nil then return n end
    return def
end

local function toolAttr(tool, name)
    local ok, attrs = pcall(function() return tool:GetAttrs() end)
    if ok and attrs then
        return attrs[name]
    end
    return nil
end

local function toolName(tool)
    local name = toolAttr(tool, "TOOLS_Name") or toolAttr(tool, "TOOLST_Name")
    if name ~= nil then
        return tostring(name)
    end

    local okName, directName = pcall(function() return tool.Name end)
    if okName and directName ~= nil then
        return tostring(directName)
    end

    return nil
end

local function isCurrentToolSelected()
    local selectedAttr = toolAttr(self, "TOOLB_Selected")
    if selectedAttr == true or selectedAttr == 1 then
        return true
    end

    local comp = nil
    pcall(function() comp = self.Comp end)
    if comp == nil then
        pcall(function() comp = self:GetComp() end)
    end

    if comp ~= nil then
        local okActive, activeTool = pcall(function() return comp.ActiveTool end)
        if okActive and activeTool ~= nil then
            if activeTool == self then
                return true
            end
            local selfName = toolName(self)
            local activeName = toolName(activeTool)
            if selfName ~= nil and activeName ~= nil and selfName == activeName then
                return true
            end
        end

        local okSelected, selectedTools = pcall(function() return comp:GetToolList(true) end)
        if okSelected and selectedTools ~= nil then
            local selfName = toolName(self)
            for _, tool in pairs(selectedTools) do
                if tool == self then
                    return true
                end
                local selectedName = toolName(tool)
                if selfName ~= nil and selectedName ~= nil and selfName == selectedName then
                    return true
                end
            end
        end
    end

    return false
end

local function debugVisualState(req)
    local renderToOutput = inputNumber(InDebugRenderToOutput, req, 1) >= 0.5
    local selectedPreview = isCurrentToolSelected()
    return renderToOutput or selectedPreview, renderToOutput, selectedPreview
end

local function resetFpsMetrics(metrics)
    metrics.enabled = false
    metrics.prevTime = nil
    metrics.frameCount = 0
    metrics.lastFrameTime = nil
end

local function logFpsMetrics(enabled, req, w, h)
    local metrics = RuntimeCache.fpsMetrics

    if not enabled then
        if metrics.enabled then
            print("[PuppetPin] FPS metrics disabled")
        end
        resetFpsMetrics(metrics)
        return
    end

    local okClock, now = pcall(function() return os.clock() end)
    if (not okClock) or type(now) ~= "number" then
        return
    end

    if not metrics.enabled then
        metrics.enabled = true
        metrics.prevTime = now
        metrics.frameCount = 0
        metrics.lastFrameTime = nil
    end

    local delta = now - (metrics.prevTime or now)
    metrics.prevTime = now
    metrics.frameCount = metrics.frameCount + 1

    local frameTime = req and req.Time or "?"
    local repeatedFrame = metrics.lastFrameTime ~= nil and tostring(metrics.lastFrameTime) == tostring(frameTime)
    metrics.lastFrameTime = frameTime

    if delta > 0 then
        local fps = 1.0 / delta
        local frameMs = delta * 1000.0
        print(string.format("[PuppetPin] Sample %d | Frame %s%s | FPS: %.1f | Frame Time: %.2f ms | Size: %dx%d", metrics.frameCount, tostring(frameTime), repeatedFrame and " repeated" or "", fps, frameMs, w or 0, h or 0))
    else
        print(string.format("[PuppetPin] Sample %d | Frame %s%s | FPS: -- | Frame Time: -- ms | Size: %dx%d", metrics.frameCount, tostring(frameTime), repeatedFrame and " repeated" or "", w or 0, h or 0))
    end
end

-- Safe point getter for PointControl-style inputs.
local function inputPoint(inp, req, defX, defY)
    local ok, p = pcall(function() return inp:GetValue(req) end)
    if (not ok) or p == nil then return defX, defY end

    local x, y

    if type(p) == "table" then
        x = p.X or p[1]
        y = p.Y or p[2]
    else
        local okx, vx = pcall(function() return p.X end)
        local oky, vy = pcall(function() return p.Y end)
        if okx then x = vx end
        if oky then y = vy end
    end

    x = tonumber(x) or defX
    y = tonumber(y) or defY

    return x, y
end

local function resolveWaveTime(req)
    local reqTime = tonumber(req and req.Time)
    local compTime = nil

    local c = nil
    pcall(function() c = self.Comp end)
    if c == nil then
        pcall(function() c = self:GetComp() end)
    end
    if c ~= nil then
        local okCompTime, ct = pcall(function() return c.CurrentTime end)
        if okCompTime then
            compTime = tonumber(ct)
        end
    end

    if reqTime ~= nil then
        local isQuick = false
        local okQuick, quickValue = pcall(function() return req:IsQuick() end)
        if okQuick then
            isQuick = quickValue and true or false
        end

        if isQuick and compTime ~= nil and math.abs(compTime - reqTime) > 1e-6 then
            return compTime
        end
        return reqTime
    end

    if compTime ~= nil then return compTime end
    return 0
end

-- Return pin falloff weight from normalized distance t (0 center -> 1 edge).
local function computeFalloff(mode, t)
    -- t: 0 at pin center, 1 at radius edge
    t = clamp(t, 0.0, 1.0)

    if mode == 0 then
        return 1.0 - t
    elseif mode == 1 then
        local s = 1.0 - t
        return s * s * (3.0 - (2.0 * s))
    else
        local edge = math.exp(-4.5)
        local g = (math.exp(-4.5 * t * t) - edge) / (1.0 - edge)
        return clamp(g, 0.0, 1.0)
    end
end

-- Compute final displacement vector at one mesh vertex from all active pins.
local function computePinDisplacementAt(x, y, pins, influenceMode, falloffMode, maxDisplacePx, rootLockEnabled, rootPx, rootPy, rootRadiusPx, rootLockStrength)
    local totalX, totalY = 0.0, 0.0
    local affected = false
    local maxAbsForce2 = -1.0
    local normWeight = 0.0
    local gaussEdge = math.exp(-4.5)
    local gaussNorm = 1.0 - gaussEdge

    -- Accumulate per-pin forces at this vertex.
    for _, pin in ipairs(pins) do
        if x < pin.minx or x > pin.maxx or y < pin.miny or y > pin.maxy then
            goto continue_pin
        end

        local dx = x - pin.px
        local dy = y - pin.py
        local dist2 = (dx * dx) + (dy * dy)
        if dist2 < pin.r2 then
            local falloff
            local dist = nil
            local t = nil
            if falloffMode == 2 then
                -- Gaussian can work directly on squared normalized distance.
                local t2 = dist2 * pin.invR2
                falloff = (math.exp(-4.5 * t2) - gaussEdge) / gaussNorm
                if falloff < 0.0 then falloff = 0.0 end
            else
                dist = math.sqrt(dist2)
                t = dist * pin.invRadius
                falloff = computeFalloff(falloffMode, t)
            end

            -- Stabilize the outer edge of pin influence: fade out aggressively near
            -- radius boundary so the last vertex ring does not create seam rows.
            if t == nil then
                t = math.sqrt(dist2) * pin.invRadius
            end
            if t > 0.90 then
                local u = (1.0 - t) * 10.0
                u = clamp(u, 0.0, 1.0)
                local edgeFade = u * u * (3.0 - (2.0 * u))
                falloff = falloff * edgeFade
            end
            if falloff < 1e-3 then
                goto continue_pin
            end
            if falloff > 1e-6 then
                local ux, uy = 0.0, 0.0
                local needRadial = (math.abs(pin.expansion) > 1e-6) or (math.abs(pin.rotationRad) > 1e-6)
                if needRadial and dist2 > 1e-12 then
                    local invDist = 1.0 / math.sqrt(dist2)
                    ux = dx * invDist
                    uy = dy * invDist
                end

                -- Pull translates nearby vertices by pin movement delta from bind pose.
                local fx = pin.moveX * pin.pull * falloff
                local fy = pin.moveY * pin.pull * falloff

                -- Expansion moves vertices radially around the pin.
                if math.abs(pin.expansion) > 1e-6 then
                    local expForce = pin.expansion * pin.radius * falloff
                    fx = fx + (ux * expForce)
                    fy = fy + (uy * expForce)
                end

                -- Rotation moves vertices tangentially around the pin.
                if math.abs(pin.rotationRad) > 1e-6 and dist2 > 1e-12 then
                    local tx = -uy
                    local ty = ux
                    local rotForce = pin.rotationRad * pin.radius * 0.35 * falloff
                    fx = fx + (tx * rotForce)
                    fy = fy + (ty * rotForce)
                end

                local force2 = (fx * fx) + (fy * fy)
                if force2 > 1e-12 then
                    affected = true
                    -- Influence composition:
                    -- 0=Additive, 1=Strongest pin only, 2=Normalized blend.
                    if influenceMode == 1 then
                        if force2 > maxAbsForce2 then
                            maxAbsForce2 = force2
                            totalX = fx
                            totalY = fy
                        end
                    else
                        totalX = totalX + fx
                        totalY = totalY + fy
                        if influenceMode == 2 then
                            normWeight = normWeight + falloff
                        end
                    end
                end
            end
        end
        ::continue_pin::
    end

    if not affected then
        return 0.0, 0.0, false
    end

    if influenceMode == 2 and normWeight > 1e-6 then
        totalX = totalX / normWeight
        totalY = totalY / normWeight
    end

    if rootLockEnabled then
        local rdx = x - rootPx
        local rdy = y - rootPy
        local rdist2 = (rdx * rdx) + (rdy * rdy)
        local rr2 = rootRadiusPx * rootRadiusPx
        if rdist2 < rr2 then
            local rt = math.sqrt(rdist2) / rootRadiusPx
            local rootFalloff = computeFalloff(1, rt)
            local lockAmount = clamp(rootLockStrength * rootFalloff, 0.0, 1.0)
            local keep = 1.0 - lockAmount
            totalX = totalX * keep
            totalY = totalY * keep
        end
    end

    local dispMag2 = (totalX * totalX) + (totalY * totalY)
    local maxDisp2 = maxDisplacePx * maxDisplacePx
    if dispMag2 > maxDisp2 and dispMag2 > 1e-12 then
        local s = maxDisplacePx / math.sqrt(dispMag2)
        totalX = totalX * s
        totalY = totalY * s
    end

    return totalX, totalY, true
end

-- Warp one source triangle into deformed triangle using barycentric mapping.
local function warpMeshTriangle(out, srcImg, a0, b0, c0, a1, b1, c1, w, h, qualityMode, alphaClip, sp, ap, dp)
    local den = ((b1.y - c1.y) * (a1.x - c1.x)) + ((c1.x - b1.x) * (a1.y - c1.y))
    if math.abs(den) < 1e-8 then return end

    local a0x, a0y = a0.sx or a0.x, a0.sy or a0.y
    local b0x, b0y = b0.sx or b0.x, b0.sy or b0.y
    local c0x, c0y = c0.sx or c0.x, c0.sy or c0.y

    -- Use a conservative bbox to avoid dropping boundary pixels on shared triangle edges.
    local minX = math.max(0, math.floor(math.min(a1.x, math.min(b1.x, c1.x)) - 0.5))
    local maxX = math.min(w - 1, math.ceil(math.max(a1.x, math.max(b1.x, c1.x)) + 0.5))
    local minY = math.max(0, math.floor(math.min(a1.y, math.min(b1.y, c1.y)) - 0.5))
    local maxY = math.min(h - 1, math.ceil(math.max(a1.y, math.max(b1.y, c1.y)) + 0.5))

    if maxX < minX or maxY < minY then return end

    -- Slightly relaxed edge test helps produce watertight fills across adjacent triangles.
    local eps = -1.5e-3
    -- Rasterize destination triangle and back-project each covered pixel into
    -- source triangle using barycentric coordinates.
    for y = minY, maxY do
        local py = y + 0.5
        for x = minX, maxX do
            local px = x + 0.5

            local w1 = (((b1.y - c1.y) * (px - c1.x)) + ((c1.x - b1.x) * (py - c1.y))) / den
            local w2 = (((c1.y - a1.y) * (px - c1.x)) + ((a1.x - c1.x) * (py - c1.y))) / den
            local w3 = 1.0 - w1 - w2

            if w1 >= eps and w2 >= eps and w3 >= eps then
                local sx = (w1 * a0x) + (w2 * b0x) + (w3 * c0x)
                local sy = (w1 * a0y) + (w2 * b0y) + (w3 * c0y)
                local ax = (w1 * a0.x) + (w2 * b0.x) + (w3 * c0.x)
                local ay = (w1 * a0.y) + (w2 * b0.y) + (w3 * c0.y)
                sx = clamp(sx, 0, w - 1)
                sy = clamp(sy, 0, h - 1)
                ax = clamp(ax, 0, w - 1)
                ay = clamp(ay, 0, h - 1)

                if qualityMode == 0 then
                    srcImg:GetPixel(math.floor(sx + 0.5), math.floor(sy + 0.5), sp)
                    srcImg:GetPixel(math.floor(ax + 0.5), math.floor(ay + 0.5), ap)
                else
                    srcImg:SamplePixelB(sx, sy, sp)
                    srcImg:SamplePixelB(ax, ay, ap)
                end

                local outA = tonumber(ap.A) or 0.0
                if outA <= alphaClip then
                    goto continue_pixel
                end

                dp.R = sp.R
                dp.G = sp.G
                dp.B = sp.B
                dp.A = outA
                out:SetPixel(x, y, dp)
            end
            ::continue_pixel::
        end
    end
end

-- Main Process Function
function Process(req)
    -- Periodic incremental GC step keeps long interactive sessions stable.
    RuntimeCache.frame = RuntimeCache.frame + 1
    if (RuntimeCache.frame % 30) == 0 then
        -- Keep Lua heap from growing during long interactive drags.
        collectgarbage("step", 64)
    end

    -- Fetch and validate input frame.
    local img = InImage:GetValue(req)
    if not img then return end

    local w = tonumber(img.Width)
    local h = tonumber(img.Height)
    if not w or not h then
        OutImage:Set(req, img)
        return
    end
    local logFpsEnabled = inputNumber(InLogFpsMetrics, req, 0) >= 0.5

    -- Read all mesh controls for this request/frame.
    local minDim = math.min(w, h)
    local rigMode = math.floor(clamp(inputNumber(InRigMode, req, 0), 0, 1)) -- 0=Setup, 1=Animate
    local waveTime = resolveWaveTime(req)
    local canDeform = (rigMode == 1)
    local useMeshMask = false
    local meshRebuild = 0
    local maskAlphaThreshold = clamp(inputNumber(InMaskAlphaThreshold, req, 0.03), 0.0, 1.0)
    local maskDownsample = math.floor(clamp(inputNumber(InMaskDownsample, req, 1), 1, 8))
    local interiorSpacing = clamp(inputNumber(InMeshInteriorDensity, req, 32), 4, 256)
    local interiorJitter = clamp(inputNumber(InMeshInteriorJitter, req, 0.0), 0.0, 1.0)
    local contourSpacing = clamp(inputNumber(InMeshContourDensity, req, 32), 4, 256)
    local meshExpand = clamp(inputNumber(InMeshExpand, req, 0.02), 0.0, 1.0)
    local borderExpandPx = meshExpand * (0.10 * minDim)
    local meshAlwaysDisplay = inputNumber(InMeshAlwaysDisplay, req, 0) >= 0.5
    local drawDebugVisuals, renderDebugToOutput, selectedDebugPreview = debugVisualState(req)
    local selectedPreviewOnly = selectedDebugPreview and not renderDebugToOutput
    local meshDebug = ((meshAlwaysDisplay or (MeshPreviewCountdown > 0)) and drawDebugVisuals) or selectedPreviewOnly
    local meshThickness = math.floor(clamp(inputNumber(InMeshThickness, req, 2), 1, 5))
    local meshColorR = clamp(inputNumber(InMeshColor, req, 0.95), 0.0, 1.0)
    local meshColorG = clamp(inputNumber(InMeshColorG, req, 0.2), 0.0, 1.0)
    local meshColorB = clamp(inputNumber(InMeshColorB, req, 0.2), 0.0, 1.0)
    -- Mesh generation uses the primary image alpha.
    local meshSrc = img

    -- Mesh cache key captures all settings that affect geometry.
    local meshKey = string.format(
        "%dx%d|%d|%.3f|%d|%.3f|%.3f|%.3f|%.3f|%d|%.3f",
        w, h,
        useMeshMask and 1 or 0,
        maskAlphaThreshold,
        maskDownsample,
        interiorSpacing,
        contourSpacing,
        meshExpand,
        borderExpandPx,
        meshRebuild,
        meshRebuild == 1 and req.Time or 0
    )
    -- Rebuild mesh only when relevant settings actually changed.
    if MeshCache.key ~= meshKey then
        local region = buildMaskRegion(meshSrc, w, h, meshExpand, maskAlphaThreshold, maskDownsample)
        local verts, tris, contourCount = buildGridMesh(region, interiorSpacing, contourSpacing, borderExpandPx, meshSrc, maskAlphaThreshold, interiorJitter)
        local maskCache = buildMaskCache(meshSrc, region, maskAlphaThreshold)
        MeshCache.key = meshKey
        MeshCache.region = region
        MeshCache.verts = verts
        MeshCache.tris = tris
        MeshCache.contourCount = contourCount or 0
        MeshCache.mask = maskCache
    end
    local meshRegion = MeshCache.region
    local meshVerts = MeshCache.verts
    local meshTris = MeshCache.tris
    local meshContourCount = MeshCache.contourCount or 0
    local meshMaskCache = MeshCache.mask

    -- Read deformation/solver/debug controls.
    local falloffMode = math.floor(clamp(inputNumber(InFalloffMode, req, 1), 0, 2))
    local influenceMode = math.floor(clamp(inputNumber(InInfluenceMode, req, 0), 0, 2))
    local maxDisplaceN = clamp(inputNumber(InMaxDisplace, req, 0.20), 0.001, 2.0)
    local maxDisplacePx = maxDisplaceN * minDim
    local qualityMode = math.floor(clamp(inputNumber(InQualityMode, req, 1), 0, 1))
    local debugOverlay = ((inputNumber(InDebugOverlay, req, 0) >= 0.5) and drawDebugVisuals) or selectedPreviewOnly
    local debugAlpha = clamp(inputNumber(InDebugAlpha, req, 0.35), 0.0, 1.0)
    local meshDiagnosticMode = drawDebugVisuals and math.floor(clamp(inputNumber(InMeshDiagnosticMode, req, 0), 0, 3)) or 0
    local meshDiagnosticThreshold = clamp(inputNumber(InMeshDiagnosticThreshold, req, 80.0), 1.0, 2048.0)
    local meshDebugOutputMode = drawDebugVisuals and math.floor(clamp(inputNumber(InMeshDebugOutputMode, req, 0), 0, 3)) or 0
    local meshFillCracks = inputNumber(InMeshFillCracks, req, 0) >= 0.5
    local rootLockEnabled = inputNumber(InRootLockEnable, req, 0) >= 0.5
    local rootLockStrength = clamp(inputNumber(InRootLockStrength, req, 1.0), 0.0, 1.0)
    local useWeightMask = inputNumber(InUseWeightMask, req, 0) >= 0.5
    local weightMaskLock = clamp(inputNumber(InWeightMaskLock, req, 1.0), 0.0, 1.0)
    -- Optional weight mask lock setup.
    local weightMaskImg = nil
    local weightMaskPixel = nil
    if useWeightMask and weightMaskLock > 1e-6 then
        local okW, wm = pcall(function() return InWeightMask:GetValue(req) end)
        if okW and wm then
            weightMaskImg = wm
            weightMaskPixel = Pixel(weightMaskImg)
        else
            useWeightMask = false
        end
    else
        useWeightMask = false
    end

    -- Optional root lock setup.
    local rootPx, rootPy, rootRadiusPx = 0.0, 0.0, 1.0
    if rootLockEnabled and rootLockStrength > 1e-6 then
        local rxNorm, ryNorm = inputPoint(InRootLockPos, req, 0.5, 0.5)
        local rootRadiusN = clamp(inputNumber(InRootLockRadius, req, 0.15), 0.001, 2.0)
        rootPx = rxNorm * w
        rootPy = ryNorm * h
        rootRadiusPx = math.max(1.0, rootRadiusN * minDim)
    else
        rootLockEnabled = false
    end

    -- Build active pin runtime structs and active influence bounds.
    local pins = RuntimeCache.pins
    local activePins = RuntimeCache.activePins
    local prevPinX = RuntimeCache.prevPinX
    local prevPinY = RuntimeCache.prevPinY
    local pinCount = 0
    local activePinCount = 0
    local interacting = false
    local ax0, ay0 = w - 1, h - 1
    local ax1, ay1 = 0, 0

    for i = 1, MAX_PINS do
        local enabled = inputNumber(PinEnabled[i], req, (i == 1) and 1 or 0)
        if enabled >= 0.5 then
            local xNorm, yNorm = inputPoint(PinPos[i], req, 0.5, 0.5)
            local pull = inputNumber(PinStrength[i], req, 1.0)
            local radiusN = clamp(inputNumber(PinRadius[i], req, 0.20), 0.001, 2.0)
            local radiusPx = math.max(1.0, radiusN * minDim)
            local rotationDeg = inputNumber(PinRotation[i], req, 0.0)
            local expansion = inputNumber(PinExpansion[i], req, 0.0)
            local px = xNorm * w
            local py = yNorm * h

            local ppx = prevPinX[i]
            local ppy = prevPinY[i]
            if ppx ~= nil and ppy ~= nil then
                local md = math.abs(px - ppx) + math.abs(py - ppy)
                if md > 0.30 then
                    interacting = true
                end
            end
            prevPinX[i] = px
            prevPinY[i] = py

            if PinBindPose[i] == nil or rigMode == 0 then
                PinBindPose[i] = { x = px, y = py }
            end

            if radiusPx > 1.0 then
                local r = radiusPx
                pinCount = pinCount + 1
                local p = pins[pinCount]
                if p == nil then
                    p = {}
                    pins[pinCount] = p
                end
                p.idx = i
                p.px = px
                p.py = py
                p.bindX = PinBindPose[i].x
                p.bindY = PinBindPose[i].y
                p.pull = pull
                p.rotationRad = (rotationDeg * math.pi) / 180.0
                p.expansion = expansion
                p.radius = r
                p.invRadius = 1.0 / r
                p.r2 = r * r
                p.invR2 = 1.0 / p.r2
                p.minx = px - r
                p.maxx = px + r
                p.miny = py - r
                p.maxy = py + r
                p.moveX = p.px - p.bindX
                p.moveY = p.py - p.bindY
            end
        else
            prevPinX[i] = nil
            prevPinY[i] = nil
        end
    end

    -- Apply follower offsets after all pins are collected so source/target lookup is stable.
    if canDeform and pinCount > 1 then
        for fi = 1, MAX_FOLLOWERS do
            if inputNumber(FollowerEnable[fi], req, 0) >= 0.5 then
                local followerSource = math.floor(clamp(inputNumber(FollowerSource[fi], req, 1), 1, MAX_PINS))
                local followerTarget = math.floor(clamp(inputNumber(FollowerTarget[fi], req, 2), 1, MAX_PINS))
                if followerSource ~= followerTarget then
                    local followerAmpX = inputNumber(FollowerAmpX[fi], req, 1.0)
                    local followerAmpY = inputNumber(FollowerAmpY[fi], req, 1.0)
                    local followerAmpRot = inputNumber(FollowerAmpRot[fi], req, 0.0)
                    local followerAmpExp = inputNumber(FollowerAmpExp[fi], req, 0.0)

                    local srcPin = nil
                    local tgtPin = nil
                    for i = 1, pinCount do
                        local p = pins[i]
                        if p.idx == followerSource then srcPin = p end
                        if p.idx == followerTarget then tgtPin = p end
                    end
                    if srcPin and tgtPin then
                        local sdx = srcPin.px - srcPin.bindX
                        local sdy = srcPin.py - srcPin.bindY
                        tgtPin.px = clamp(tgtPin.px + (sdx * followerAmpX), 0, w - 1)
                        tgtPin.py = clamp(tgtPin.py + (sdy * followerAmpY), 0, h - 1)
                        tgtPin.rotationRad = tgtPin.rotationRad + (srcPin.rotationRad * followerAmpRot)
                        tgtPin.expansion = tgtPin.expansion + (srcPin.expansion * followerAmpExp)
                    end
                end
            end
        end
    end

    -- Wave v1: sinusoidal offset over pin-ID chain segment for cloth/hair motion.
    if canDeform and pinCount > 1 then
        for wi = 1, MAX_WAVES do
            if inputNumber(WaveEnable[wi], req, 0) >= 0.5 then
                local waveBase = math.floor(clamp(inputNumber(WaveBase[wi], req, 1), 1, MAX_PINS))
                local waveStart = math.floor(clamp(inputNumber(WaveStart[wi], req, 2), 1, MAX_PINS))
                local waveEnd = math.floor(clamp(inputNumber(WaveEnd[wi], req, 6), 1, MAX_PINS))
                local waveAmpPx = clamp(inputNumber(WaveAmp[wi], req, 0.03), 0.0, 1.0) * minDim
                local waveFreq = clamp(inputNumber(WaveFreq[wi], req, 1.5), 0.01, 20.0)
                local waveSpeed = inputNumber(WaveSpeed[wi], req, 1.0)
                local wavePhase = inputNumber(WavePhase[wi], req, 0.0)
                local waveStretch = clamp(inputNumber(WaveStretch[wi], req, 0.0), -1.0, 1.0)

                if waveAmpPx > 1e-6 then
                    local chainLo = math.min(waveStart, waveEnd)
                    local chainHi = math.max(waveStart, waveEnd)
                    local chainSpan = math.max(1, chainHi - chainLo)
                    local basePin = nil
                    for i = 1, pinCount do
                        if pins[i].idx == waveBase then
                            basePin = pins[i]
                            break
                        end
                    end

                    if basePin then
                        local timePhase = waveTime * waveSpeed
                        local twoPi = 2.0 * math.pi
                        for i = 1, pinCount do
                            local p = pins[i]
                            local id = p.idx
                            if id >= chainLo and id <= chainHi and id ~= waveBase then
                                local tx = (id - chainLo) / chainSpan
                                local bvx = p.bindX - basePin.bindX
                                local bvy = p.bindY - basePin.bindY
                                local bl = math.sqrt((bvx * bvx) + (bvy * bvy))
                                if bl > 1e-6 then
                                    local ux = bvx / bl
                                    local uy = bvy / bl
                                    local nx = -uy
                                    local ny = ux

                                    local phase = wavePhase + timePhase + (tx * waveFreq * twoPi)
                                    local s = math.sin(phase)
                                    local c = math.cos(phase)

                                    local amp = waveAmpPx * (0.6 + 0.4 * tx)
                                    p.px = clamp(p.px + (nx * amp * s), 0, w - 1)
                                    p.py = clamp(p.py + (ny * amp * s), 0, h - 1)

                                    if math.abs(waveStretch) > 1e-6 then
                                        local along = bl * waveStretch * c * 0.15 * (0.3 + 0.7 * tx)
                                        p.px = clamp(p.px + (ux * along), 0, w - 1)
                                        p.py = clamp(p.py + (uy * along), 0, h - 1)
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    -- Rebuild active deformation set after follower constraints are applied.
    for i = 1, pinCount do
        local p = pins[i]
        p.moveX = p.px - p.bindX
        p.moveY = p.py - p.bindY
        p.minx = p.px - p.radius
        p.maxx = p.px + p.radius
        p.miny = p.py - p.radius
        p.maxy = p.py + p.radius
        local activeMag = math.abs(p.moveX * p.pull) + math.abs(p.moveY * p.pull) + math.abs(p.rotationRad * p.radius) + math.abs(p.expansion * p.radius)
        if activeMag > 1e-4 then
            activePinCount = activePinCount + 1
            activePins[activePinCount] = p
            -- Keep deformation bounds conservative to avoid seam flicker at radius edges.
            local pad = math.max(4.0, maxDisplacePx + 2.0)
            local px0 = math.floor(math.min(p.bindX, p.px) - p.radius - pad)
            local py0 = math.floor(math.min(p.bindY, p.py) - p.radius - pad)
            local px1 = math.floor(math.max(p.bindX, p.px) + p.radius + pad)
            local py1 = math.floor(math.max(p.bindY, p.py) + p.radius + pad)
            if px0 < ax0 then ax0 = px0 end
            if py0 < ay0 then ay0 = py0 end
            if px1 > ax1 then ax1 = px1 end
            if py1 > ay1 then ay1 = py1 end
        end
    end

    -- Trim reused tables when active pin count shrinks.
    for i = pinCount + 1, #pins do pins[i] = nil end
    for i = activePinCount + 1, #activePins do activePins[i] = nil end

    -- Fast exits when nothing needs deformation or debug rendering.
    if pinCount == 0 and not meshDebug and meshDiagnosticMode == 0 and meshDebugOutputMode == 0 then
        logFpsMetrics(logFpsEnabled, req, w, h)
        OutImage:Set(req, img)
        return
    end

    if canDeform and activePinCount == 0 and not meshDebug and not debugOverlay and meshDiagnosticMode == 0 and meshDebugOutputMode == 0 then
        logFpsMetrics(logFpsEnabled, req, w, h)
        OutImage:Set(req, img)
        return
    end

    -- Clamp active update bounds to image extents.
    if activePinCount > 0 then
        ax0 = clamp(ax0, 0, w - 1)
        ay0 = clamp(ay0, 0, h - 1)
        ax1 = clamp(ax1, 0, w - 1)
        ay1 = clamp(ay1, 0, h - 1)
    end

    -- Track short "interaction hold" window to keep interactive optimizations.
    if interacting then
        RuntimeCache.interactHold = 6
    elseif RuntimeCache.interactHold > 0 then
        RuntimeCache.interactHold = RuntimeCache.interactHold - 1
    end
    local liveInteracting = (RuntimeCache.interactHold > 0)

    -- Interaction-aware GC policy:
    -- - while dragging: frequent small steps to avoid heap spikes
    -- - on drag end: one full sweep to reclaim temporary allocations
    if liveInteracting then
        collectgarbage("step", 128)
    else
        if RuntimeCache.wasInteracting then
            collectgarbage("collect")
        end
        collectgarbage("step", 48)
    end
    RuntimeCache.wasInteracting = liveInteracting

    local liveQualityMode = qualityMode
    local liveDebugOverlay = debugOverlay

    -- Output starts as copy of source; deformation writes into this image.
    local out = img:CopyOf()
    local deformedVerts = meshVerts
    local clearPixel = Pixel(out)
    clearPixel.R = 0.0
    clearPixel.G = 0.0
    clearPixel.B = 0.0
    clearPixel.A = 0.0

    if meshDebugOutputMode == 1 then
        for y = 0, h - 1 do
            for x = 0, w - 1 do
                out:SetPixel(x, y, clearPixel)
            end
        end
    end

    -- Deformation pass: move mesh vertices, clear old subject area, re-rasterize triangles.
    if meshVerts and meshTris and #meshVerts >= 3 and #meshTris >= 1 and activePinCount > 0 and canDeform then
        -- Clear original masked subject area first so displaced mesh doesn't leave a ghost behind.
        -- Vertex solve pass.
        deformedVerts = DeformCache.verts
        for i = 1, #meshVerts do
            local vx = meshVerts[i].x
            local vy = meshVerts[i].y
            if vx < ax0 or vx > ax1 or vy < ay0 or vy > ay1 then
                local dv = deformedVerts[i] or {}
                dv.x = vx
                dv.y = vy
                deformedVerts[i] = dv
                goto continue_vert
            end
            local dx, dy, moved = computePinDisplacementAt(
                vx, vy, activePins, influenceMode, falloffMode, maxDisplacePx,
                rootLockEnabled, rootPx, rootPy, rootRadiusPx, rootLockStrength
            )
            if moved and useWeightMask and weightMaskImg and weightMaskPixel then
                local wx = clamp(math.floor(vx + 0.5), 0, weightMaskImg.Width - 1)
                local wy = clamp(math.floor(vy + 0.5), 0, weightMaskImg.Height - 1)
                weightMaskImg:GetPixel(wx, wy, weightMaskPixel)
                local lockV = clamp(maskValueAtPixel(weightMaskPixel), 0.0, 1.0) * weightMaskLock
                local keep = 1.0 - lockV
                dx = dx * keep
                dy = dy * keep
            end
            if moved then
                local dv = deformedVerts[i] or {}
                dv.x = clamp(vx + dx, 0, w - 1)
                dv.y = clamp(vy + dy, 0, h - 1)
                deformedVerts[i] = dv
            else
                local dv = deformedVerts[i] or {}
                dv.x = vx
                dv.y = vy
                deformedVerts[i] = dv
            end
            ::continue_vert::
        end
        -- If mesh was rebuilt smaller, drop stale cached vertices from prior larger mesh.
        for i = #meshVerts + 1, #deformedVerts do
            deformedVerts[i] = nil
        end

        -- Clear old subject pixels in active region before writing warped mesh.
        local cp = Pixel(out)
        local mx0 = clamp(math.max(math.floor(meshRegion.x0), ax0), 0, w - 1)
        local my0 = clamp(math.max(math.floor(meshRegion.y0), ay0), 0, h - 1)
        local mx1 = clamp(math.min(math.floor(meshRegion.x1), ax1), 0, w - 1)
        local my1 = clamp(math.min(math.floor(meshRegion.y1), ay1), 0, h - 1)
        if meshDebugOutputMode == 2 then
            mx0 = clamp(math.floor(meshRegion.x0), 0, w - 1)
            my0 = clamp(math.floor(meshRegion.y0), 0, h - 1)
            mx1 = clamp(math.floor(meshRegion.x1), 0, w - 1)
            my1 = clamp(math.floor(meshRegion.y1), 0, h - 1)
        end
        for y = my0, my1 do
            for x = mx0, mx1 do
                local inMask = false
                if meshMaskCache ~= nil then
                    local lx = x - meshMaskCache.x0
                    local ly = y - meshMaskCache.y0
                    if lx >= 0 and ly >= 0 and lx < meshMaskCache.w and ly < meshMaskCache.h then
                        local mi = (ly * meshMaskCache.w) + lx + 1
                        inMask = (meshMaskCache.data[mi] == 1)
                    end
                end
                if inMask then
                    cp.R = 0.0
                    cp.G = 0.0
                    cp.B = 0.0
                    cp.A = 0.0
                    out:SetPixel(x, y, cp)
                end
            end
        end

        -- Triangle warp pass (source mesh -> deformed mesh).
        local sp = Pixel(img)
        local ap = Pixel(img)
        local dp = Pixel(out)
        -- Triangle-by-triangle warp from bind mesh to deformed mesh.
        for ti = 1, #meshTris do
            local t = meshTris[ti]
            local a0 = meshVerts[t[1]]
            local b0 = meshVerts[t[2]]
            local c0 = meshVerts[t[3]]
            local a1 = deformedVerts[t[1]]
            local b1 = deformedVerts[t[2]]
            local c1 = deformedVerts[t[3]]
            local tx0 = math.min(a1.x, math.min(b1.x, c1.x))
            local ty0 = math.min(a1.y, math.min(b1.y, c1.y))
            local tx1 = math.max(a1.x, math.max(b1.x, c1.x))
            local ty1 = math.max(a1.y, math.max(b1.y, c1.y))
            if tx1 < ax0 or tx0 > ax1 or ty1 < ay0 or ty0 > ay1 then
                goto continue_tri
            end
            warpMeshTriangle(out, img, a0, b0, c0, a1, b1, c1, w, h, liveQualityMode, maskAlphaThreshold, sp, ap, dp)
            ::continue_tri::
        end

        -- Fill small transparent holes produced by triangle raster gaps.
        -- Post-fill tiny transparent cracks from triangle raster boundaries.
        local bx0 = math.max(0, ax0 - 3)
        local by0 = math.max(0, ay0 - 3)
        local bx1 = math.min(w - 1, ax1 + 3)
        local by1 = math.min(h - 1, ay1 + 3)

        local p0 = Pixel(out)
        local pn = Pixel(out)
        local pf = Pixel(out)
        local holeFillPasses = 0
        if (not meshFillCracks) or meshDebugOutputMode == 3 then
            holeFillPasses = 0
        elseif canDeform and liveInteracting then
            -- Keep at least one pass while moving to avoid temporal seam flicker.
            holeFillPasses = 1
        elseif qualityMode == 1 then
            if #meshTris > 1800 then
                holeFillPasses = 1
            else
                holeFillPasses = 2
            end
        end

        -- Local hole-fill around active bounds to hide tiny raster cracks.
        for _ = 1, holeFillPasses do
            for y = by0, by1 do
                for x = bx0, bx1 do
                    out:GetPixel(x, y, p0)
                    if (tonumber(p0.A) or 0.0) <= 1e-6 then
                        local sr, sg, sb, sa, c = 0.0, 0.0, 0.0, 0.0, 0
                        -- 8-neighbor gather + average of non-transparent samples.
                        for oy = -1, 1 do
                            for ox = -1, 1 do
                                if not (ox == 0 and oy == 0) then
                                    local nx = x + ox
                                    local ny = y + oy
                                    if nx >= bx0 and nx <= bx1 and ny >= by0 and ny <= by1 then
                                        out:GetPixel(nx, ny, pn)
                                        local na = tonumber(pn.A) or 0.0
                                        if na > 1e-6 then
                                            sr = sr + (tonumber(pn.R) or 0.0)
                                            sg = sg + (tonumber(pn.G) or 0.0)
                                            sb = sb + (tonumber(pn.B) or 0.0)
                                            sa = sa + na
                                            c = c + 1
                                        end
                                    end
                                end
                            end
                        end
                        local minNeighbors = (liveQualityMode == 0) and 4 or 3
                        if c >= minNeighbors then
                            pf.R = sr / c
                            pf.G = sg / c
                            pf.B = sb / c
                            pf.A = sa / c
                            out:SetPixel(x, y, pf)
                        end
                    end
                end
            end
        end
    end

    -- Optional influence visualization overlay.
    if liveDebugOverlay and #pins > 0 then
        local ov = Pixel(out)
        local ip = Pixel(out)
        local overlayScale = clamp(debugAlpha, 0.0, 1.0)
        local x0, y0 = w - 1, h - 1
        local x1, y1 = 0, 0

        for i = 1, #pins do
            local p = pins[i]
            x0 = math.min(x0, math.floor(clamp(p.px - p.radius - 1, 0, w - 1)))
            x1 = math.max(x1, math.floor(clamp(p.px + p.radius + 1, 0, w - 1)))
            y0 = math.min(y0, math.floor(clamp(p.py - p.radius - 1, 0, h - 1)))
            y1 = math.max(y1, math.floor(clamp(p.py + p.radius + 1, 0, h - 1)))
        end

        for y = y0, y1 do
            for x = x0, x1 do
                local sumR, sumG, sumB, sumW = 0.0, 0.0, 0.0, 0.0
                -- Blend overlapping pin contributions into a single debug color.
                for i = 1, #pins do
                    local p = pins[i]
                    local dx = x - p.px
                    local dy = y - p.py
                    local d2 = (dx * dx) + (dy * dy)
                    if d2 < p.r2 then
                        local t = math.sqrt(d2) / p.radius
                        local wv = computeFalloff(falloffMode, t)
                        if wv > 1e-6 then
                            local cr, cg, cb = pinDebugColor(p.idx)
                            sumR = sumR + (cr * wv)
                            sumG = sumG + (cg * wv)
                            sumB = sumB + (cb * wv)
                            sumW = sumW + wv
                        end
                    end
                end

                if sumW > 1e-6 then
                    local a = clamp(overlayScale * clamp(sumW, 0.0, 1.0), 0.0, 1.0)
                    if a > 1e-6 then
                        out:GetPixel(x, y, ip)
                        local rr = sumR / sumW
                        local gg = sumG / sumW
                        local bb = sumB / sumW
                        ov.R = (tonumber(ip.R) or 0.0) * (1.0 - a) + (rr * a)
                        ov.G = (tonumber(ip.G) or 0.0) * (1.0 - a) + (gg * a)
                        ov.B = (tonumber(ip.B) or 0.0) * (1.0 - a) + (bb * a)
                        ov.A = tonumber(ip.A) or 1.0
                        out:SetPixel(x, y, ov)
                    end
                end
            end
        end

    end

    -- Draw pin handle markers.
    -- Tie pin marker visibility to the same toggle as influence overlay.
    if liveDebugOverlay and #pins > 0 then
        for i = 1, #pins do
            local r, g, b = pinDebugColor(pins[i].idx)
            drawPinMarker(out, pins[i].px, pins[i].py, w, h, r, g, b)
        end
    end

    -- Optional mesh debug render (wireframe + sampled points).
    if meshDebug and deformedVerts then
        local mp = Pixel(out)
        mp.R = meshColorR
        mp.G = meshColorG
        mp.B = meshColorB
        mp.A = 1.0
        if meshTris then
            for i = 1, #meshTris do
                local t = meshTris[i]
                local a = deformedVerts[t[1]]
                local b = deformedVerts[t[2]]
                local c = deformedVerts[t[3]]
                drawMeshLine(out, a.x, a.y, b.x, b.y, w, h, meshThickness, mp)
                drawMeshLine(out, b.x, b.y, c.x, c.y, w, h, meshThickness, mp)
                drawMeshLine(out, c.x, c.y, a.x, a.y, w, h, meshThickness, mp)
            end
        end

        local maxDebugPts = (qualityMode == 0) and 300 or 800
        local step = math.max(1, math.floor(#deformedVerts / maxDebugPts))
        for i = 1, #deformedVerts, step do
            local vx = math.floor(deformedVerts[i].x + 0.5)
            local vy = math.floor(deformedVerts[i].y + 0.5)
            drawMeshPoint(out, vx, vy, w, h, meshThickness, mp)
        end
    end

    -- Targeted diagnostics for isolating mesh/warp artifacts.
    if meshDiagnosticMode > 0 and meshVerts and meshTris and deformedVerts then
        local diag = Pixel(out)
        local function setColor(r, g, b, a)
            diag.R = r
            diag.G = g
            diag.B = b
            diag.A = a or 1.0
        end
        local function sourceXY(v)
            return v.sx or v.x, v.sy or v.y
        end
        local function edgeLen2(p, q)
            local dx = p.x - q.x
            local dy = p.y - q.y
            return (dx * dx) + (dy * dy)
        end
        local function triMaxLen2(a, b, c)
            return math.max(edgeLen2(a, b), math.max(edgeLen2(b, c), edgeLen2(c, a)))
        end
        local function drawTri(a, b, c, thickness)
            drawMeshLine(out, a.x, a.y, b.x, b.y, w, h, thickness, diag)
            drawMeshLine(out, b.x, b.y, c.x, c.y, w, h, thickness, diag)
            drawMeshLine(out, c.x, c.y, a.x, a.y, w, h, thickness, diag)
        end
        local function drawTriSource(a, b, c, thickness)
            local ax, ay = sourceXY(a)
            local bx, by = sourceXY(b)
            local cx, cy = sourceXY(c)
            drawMeshLine(out, ax, ay, bx, by, w, h, thickness, diag)
            drawMeshLine(out, bx, by, cx, cy, w, h, thickness, diag)
            drawMeshLine(out, cx, cy, ax, ay, w, h, thickness, diag)
        end
        local function drawRect(x0, y0, x1, y1, thickness)
            drawMeshLine(out, x0, y0, x1, y0, w, h, thickness, diag)
            drawMeshLine(out, x1, y0, x1, y1, w, h, thickness, diag)
            drawMeshLine(out, x1, y1, x0, y1, w, h, thickness, diag)
            drawMeshLine(out, x0, y1, x0, y0, w, h, thickness, diag)
        end

        if meshDiagnosticMode == 1 then
            local limit = math.min(meshContourCount, #meshVerts)
            setColor(0.0, 1.0, 1.0, 1.0)
            for i = 1, limit do
                local j = (i % limit) + 1
                local ax, ay = sourceXY(meshVerts[i])
                local bx, by = sourceXY(meshVerts[j])
                drawMeshLine(out, ax, ay, bx, by, w, h, meshThickness + 1, diag)
            end

            setColor(1.0, 1.0, 0.0, 1.0)
            for i = 1, limit do
                local j = (i % limit) + 1
                drawMeshLine(out, deformedVerts[i].x, deformedVerts[i].y, deformedVerts[j].x, deformedVerts[j].y, w, h, meshThickness + 1, diag)
            end

            setColor(1.0, 0.0, 1.0, 1.0)
            local threshold2 = meshDiagnosticThreshold * meshDiagnosticThreshold
            for i = 1, limit do
                local sx, sy = sourceXY(meshVerts[i])
                local dx = deformedVerts[i].x - sx
                local dy = deformedVerts[i].y - sy
                if ((dx * dx) + (dy * dy)) >= threshold2 then
                    drawMeshLine(out, sx, sy, deformedVerts[i].x, deformedVerts[i].y, w, h, meshThickness + 1, diag)
                    drawMeshPoint(out, math.floor(deformedVerts[i].x + 0.5), math.floor(deformedVerts[i].y + 0.5), w, h, meshThickness + 2, diag)
                end
            end
        elseif meshDiagnosticMode == 2 then
            local threshold2 = meshDiagnosticThreshold * meshDiagnosticThreshold
            for ti = 1, #meshTris do
                local t = meshTris[ti]
                local a = deformedVerts[t[1]]
                local b = deformedVerts[t[2]]
                local c = deformedVerts[t[3]]
                if a and b and c and triMaxLen2(a, b, c) >= threshold2 then
                    setColor(1.0, 0.0, 1.0, 1.0)
                    drawTri(a, b, c, meshThickness + 1)
                    setColor(0.0, 1.0, 1.0, 1.0)
                    drawTriSource(meshVerts[t[1]], meshVerts[t[2]], meshVerts[t[3]], meshThickness)
                end
            end
        elseif meshDiagnosticMode == 3 then
            local pad = meshDiagnosticThreshold
            local rx0 = (meshRegion and meshRegion.x0 or 0) - pad
            local ry0 = (meshRegion and meshRegion.y0 or 0) - pad
            local rx1 = (meshRegion and meshRegion.x1 or (w - 1)) + pad
            local ry1 = (meshRegion and meshRegion.y1 or (h - 1)) + pad
            if meshRegion then
                setColor(0.0, 1.0, 1.0, 1.0)
                drawRect(meshRegion.x0, meshRegion.y0, meshRegion.x1, meshRegion.y1, meshThickness + 1)
            end
            if activePinCount > 0 then
                setColor(1.0, 1.0, 0.0, 1.0)
                drawRect(ax0, ay0, ax1, ay1, meshThickness + 1)
            end
            for ti = 1, #meshTris do
                local t = meshTris[ti]
                local a = deformedVerts[t[1]]
                local b = deformedVerts[t[2]]
                local c = deformedVerts[t[3]]
                if a and b and c then
                    local tx0 = math.min(a.x, math.min(b.x, c.x))
                    local ty0 = math.min(a.y, math.min(b.y, c.y))
                    local tx1 = math.max(a.x, math.max(b.x, c.x))
                    local ty1 = math.max(a.y, math.max(b.y, c.y))
                    if tx0 < rx0 or tx1 > rx1 or ty0 < ry0 or ty1 > ry1 then
                        setColor(1.0, 0.0, 0.0, 1.0)
                        drawTri(a, b, c, meshThickness + 1)
                        setColor(0.0, 1.0, 1.0, 1.0)
                        drawTriSource(meshVerts[t[1]], meshVerts[t[2]], meshVerts[t[3]], meshThickness)
                    end
                end
            end
        end
    end

    -- Countdown for temporary mesh preview visibility.
    if MeshPreviewCountdown > 0 then
        MeshPreviewCountdown = MeshPreviewCountdown - 1
    end

    -- Publish rendered output frame.
    logFpsMetrics(logFpsEnabled, req, w, h)
    OutImage:Set(req, out)
end
